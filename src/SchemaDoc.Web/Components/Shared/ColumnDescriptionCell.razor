@if (editing)
{
    <div class="flex items-center gap-1">
        <input type="text" @bind="editValue" @onkeydown="HandleKey"
               class="flex-1 border border-blue-300 dark:border-blue-600 rounded px-2 py-0.5 text-sm bg-white dark:bg-gray-700 text-gray-800 dark:text-gray-100 focus:outline-none focus:ring-1 focus:ring-blue-300"
               placeholder="Add description..." autofocus />
        <button class="text-green-600 dark:text-green-400 hover:text-green-700 px-1" @onclick="Save" title="Save">✓</button>
        <button class="text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300 px-1" @onclick="Cancel" title="Cancel">✕</button>
    </div>
}
else
{
    <button class="w-full text-left text-sm group flex items-center gap-1 min-h-[1.5rem]"
            @onclick="StartEdit">
        @if (!string.IsNullOrWhiteSpace(InitialDescription))
        {
            <span class="text-gray-600 dark:text-gray-300">@InitialDescription</span>
        }
        else
        {
            <span class="text-gray-300 dark:text-gray-500 italic">Add description...</span>
        }
        <svg class="w-3 h-3 text-gray-300 dark:text-gray-600 opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0"
             fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
        </svg>
    </button>
}

@code {
    [Parameter] public string ColumnName { get; set; } = "";
    [Parameter] public string? InitialDescription { get; set; }
    [Parameter] public EventCallback<string?> OnSave { get; set; }

    private bool editing;
    private string editValue = "";

    protected override void OnParametersSet()
    {
        if (!editing)
            editValue = InitialDescription ?? "";
    }

    private void StartEdit()
    {
        editValue = InitialDescription ?? "";
        editing = true;
    }

    private async Task Save()
    {
        editing = false;
        await OnSave.InvokeAsync(string.IsNullOrWhiteSpace(editValue) ? null : editValue);
    }

    private void Cancel()
    {
        editing = false;
        editValue = InitialDescription ?? "";
    }

    private async Task HandleKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Save();
        else if (e.Key == "Escape") Cancel();
    }
}
