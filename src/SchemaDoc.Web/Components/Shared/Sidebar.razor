@inject SchemaDoc.Web.Services.SchemaSessionState State
@inject NavigationManager Nav
@inject IConnectionRepository ConnectionRepo
@inject SchemaDoc.Web.Services.SchemaLoaderService SchemaLoader
@inject IJSRuntime JS
@implements IDisposable

<div class="p-3">
    @if (allConnections.Count == 0)
    {
        <div class="text-xs text-gray-400 dark:text-gray-500 px-2 py-4 text-center">
            No connections yet.<br />
            <a href="/connections" class="text-blue-500 hover:underline">Add one</a>
        </div>
    }
    else
    {
        @* ── Search box (only when a schema is loaded) ──────────────── *@
        @if (State.CurrentSchema is not null)
        {
            <div class="mb-3">
                <input type="text"
                       placeholder="Search..."
                       class="w-full px-3 py-1.5 text-sm border border-gray-200 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-800 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-300 dark:focus:ring-blue-600"
                       @bind="searchText"
                       @bind:event="oninput" />
            </div>

            <button @onclick="TriggerGlobalSearch"
                    class="w-full flex items-center gap-2 px-3 py-1.5 mb-2 text-xs text-gray-400 dark:text-gray-500 hover:text-blue-500 dark:hover:text-blue-400 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
                Search all...
                <kbd class="ml-auto text-[10px] border border-gray-200 dark:border-gray-600 rounded px-1 py-0.5">Ctrl+K</kbd>
            </button>
        }

        @* ── Server connections ──────────────────────────────────── *@
        <div class="mb-2 space-y-0.5">
            @foreach (var conn in allConnections)
            {
                var isExpanded = expandedServer == conn.Id;
                var isActiveServer = State.ActiveConnection?.Id == conn.Id;
                var isLoadingDbs = loadingDbsId == conn.Id;
                var dbList = State.GetCachedDatabaseList(conn.Id);
                var hasErr = failedId == conn.Id;

                <div>
                    @* Server header *@
                    <button @onclick="() => ToggleServerAsync(conn)"
                            class="w-full flex items-center gap-1 px-2 py-1.5 rounded text-xs font-medium transition-colors @(isActiveServer ? "bg-blue-50/50 dark:bg-blue-900/20 text-gray-700 dark:text-gray-200" : hasErr ? "text-red-500 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20" : "text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700")">
                        <svg class="w-3 h-3 flex-shrink-0 transition-transform @(isExpanded ? "rotate-90" : "")"
                             fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
                        </svg>
                        <span class="truncate flex items-center gap-1 flex-1 min-w-0 text-left">
                            @if (!string.IsNullOrEmpty(conn.Tag))
                            {
                                <span class="@TagColorClass(conn.TagColor) text-[10px] px-1.5 py-0 rounded-full font-semibold leading-4 flex-shrink-0">@conn.Tag</span>
                            }
                            <span class="truncate">@conn.Name</span>
                        </span>
                        @if (isLoadingDbs)
                        {
                            <svg class="w-3 h-3 animate-spin flex-shrink-0" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path>
                            </svg>
                        }
                        else if (dbList is not null && !hasErr)
                        {
                            <span class="text-[10px] text-gray-400 dark:text-gray-500 flex-shrink-0">@dbList.Count</span>
                        }
                        else if (hasErr)
                        {
                            <svg class="w-3 h-3 flex-shrink-0 text-red-400 dark:text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" title="@failedMessage">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M12 3a9 9 0 100 18A9 9 0 0012 3z" />
                            </svg>
                        }
                    </button>

                    @* Database list under this server *@
                    @if (isExpanded && dbList is not null)
                    {
                        <div class="ml-4 mt-0.5 space-y-0.5 border-l border-gray-200 dark:border-gray-700 pl-2">
                            @if (dbList.Count == 0)
                            {
                                <div class="text-[11px] text-gray-400 dark:text-gray-500 px-2 py-1">No databases visible to this user.</div>
                            }
                            else
                            {
                                @foreach (var dbName in dbList)
                                {
                                    var isActiveDb = isActiveServer && State.ActiveDatabase == dbName;
                                    var isSwitchingDb = switchingDb == (conn.Id, dbName);
                                    var (effTag, effColor, hasOverride) = ResolveDbTag(conn, dbName);
                                    var isEditing = editingTagFor == (conn.Id, dbName);

                                    <div class="group relative">
                                        <div class="flex items-center gap-1 rounded transition-colors @(isActiveDb ? "bg-blue-100 dark:bg-blue-900/40" : "hover:bg-gray-100 dark:hover:bg-gray-700")">
                                            <button @onclick="() => SwitchToDbAsync(conn, dbName)"
                                                    disabled="@isSwitchingDb"
                                                    class="flex-1 min-w-0 flex items-center gap-1.5 px-2 py-1 text-xs @(isActiveDb ? "text-blue-700 dark:text-blue-300 font-medium" : "text-gray-600 dark:text-gray-400")">
                                                @if (!string.IsNullOrEmpty(effTag))
                                                {
                                                    <span class="@TagColorClass(effColor) text-[9px] px-1 py-0 rounded-sm font-semibold leading-3 flex-shrink-0 @(hasOverride ? "ring-1 ring-blue-400" : "")"
                                                          title="@(hasOverride ? "Database-level override" : "Inherited from server")">@effTag</span>
                                                }
                                                <span class="truncate flex-1 text-left">@dbName</span>
                                                @if (isSwitchingDb)
                                                {
                                                    <svg class="w-3 h-3 animate-spin flex-shrink-0" fill="none" viewBox="0 0 24 24">
                                                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path>
                                                    </svg>
                                                }
                                            </button>
                                            <button @onclick="() => OpenTagEditor(conn.Id, dbName)"
                                                    title="Edit tag for this database"
                                                    class="flex-shrink-0 p-1 mr-0.5 rounded text-gray-400 dark:text-gray-500 hover:text-blue-500 dark:hover:text-blue-400 hover:bg-blue-50 dark:hover:bg-blue-900/30 opacity-0 group-hover:opacity-100 @(isEditing ? "opacity-100 text-blue-500 dark:text-blue-400" : "")">
                                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
                                                </svg>
                                            </button>
                                            @if (isActiveDb)
                                            {
                                                <button @onclick:stopPropagation="true" @onclick="Disconnect"
                                                        title="Disconnect"
                                                        class="flex-shrink-0 text-blue-400 dark:text-blue-500 hover:text-red-500 dark:hover:text-red-400 transition-colors p-1 mr-0.5 rounded">
                                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
                                                    </svg>
                                                </button>
                                            }
                                        </div>

                                        @* Inline tag editor *@
                                        @if (isEditing)
                                        {
                                            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-2 mt-1 mb-1 shadow-sm">
                                                <div class="flex items-center justify-between mb-1.5">
                                                    <span class="text-[10px] font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">Tag</span>
                                                    <span class="text-[10px] text-gray-400 dark:text-gray-500">@(hasOverride ? "override" : "inherited")</span>
                                                </div>
                                                <div class="flex flex-wrap items-center gap-1 mb-1.5">
                                                    @foreach (var preset in new[] { "Dev", "Staging", "Prod", "QA" })
                                                    {
                                                        <button type="button" @onclick="() => sbEditTag = (sbEditTag == preset ? null : preset)"
                                                                class="text-[10px] px-1.5 py-0.5 rounded-full border transition-colors @(sbEditTag == preset ? "bg-blue-100 dark:bg-blue-900/40 border-blue-400 text-blue-700 dark:text-blue-300" : "border-gray-200 dark:border-gray-600 text-gray-500 dark:text-gray-400")">
                                                            @preset
                                                        </button>
                                                    }
                                                </div>
                                                <input type="text" @bind="sbEditTag" @bind:event="oninput" placeholder="Custom..."
                                                       class="w-full border border-gray-200 dark:border-gray-600 rounded px-1.5 py-1 text-xs bg-white dark:bg-gray-700 text-gray-800 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-1 focus:ring-blue-300" />
                                                <div class="flex items-center gap-1 mt-1.5">
                                                    @foreach (var (name, bg) in tagColorOptions)
                                                    {
                                                        <button type="button" @onclick="() => sbEditColor = name"
                                                                class="w-4 h-4 rounded-full @bg transition-all @(sbEditColor == name ? "ring-2 ring-offset-1 ring-blue-500 dark:ring-offset-gray-800 scale-110" : "opacity-70 hover:opacity-100")">
                                                        </button>
                                                    }
                                                </div>
                                                <div class="flex items-center gap-1.5 mt-2">
                                                    <button @onclick="SaveSidebarTagAsync"
                                                            class="bg-blue-600 hover:bg-blue-700 text-white px-2 py-0.5 rounded text-[10px] font-medium">
                                                        Save
                                                    </button>
                                                    @if (hasOverride)
                                                    {
                                                        <button @onclick="ClearSidebarTagAsync"
                                                                class="text-[10px] text-gray-500 dark:text-gray-400 hover:text-red-500 px-1">
                                                            Clear
                                                        </button>
                                                    }
                                                    <button @onclick="CloseTagEditor"
                                                            class="text-[10px] text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 ml-auto">
                                                        Cancel
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            }
                        </div>
                    }
                </div>
            }
        </div>

        @* ── Schema browser (tables/views/procs of active DB) ──────── *@
        @if (State.CurrentSchema is not null)
        {
            @if (FilteredTables.Any())
            {
                <SidebarSection Title="Tables" Icon="table" Count="@FilteredTables.Count()">
                    @foreach (var table in FilteredTables)
                    {
                        <SidebarItem Label="@table.Name"
                                     SubLabel="@table.Schema"
                                     RowCount="@table.RowCount"
                                     Href="@($"/table/{Uri.EscapeDataString(table.Schema)}/{Uri.EscapeDataString(table.Name)}")" />
                    }
                </SidebarSection>
            }

            @if (FilteredViews.Any())
            {
                <SidebarSection Title="Views" Icon="view" Count="@FilteredViews.Count()">
                    @foreach (var view in FilteredViews)
                    {
                        <SidebarItem Label="@view.Name" SubLabel="@view.Schema" Href="#" />
                    }
                </SidebarSection>
            }

            @if (FilteredProcs.Any())
            {
                <SidebarSection Title="Procedures" Icon="proc" Count="@FilteredProcs.Count()">
                    @foreach (var proc in FilteredProcs)
                    {
                        <SidebarItem Label="@proc.Name" SubLabel="@proc.Schema" Href="#" />
                    }
                </SidebarSection>
            }

            @* ── Quick links ────────────────────────────────────────── *@
            <div class="mt-3 pt-3 border-t border-gray-100 dark:border-gray-700 space-y-0.5">
                <a href="/diagram"
                   class="flex items-center gap-2 px-3 py-2 text-sm text-purple-600 dark:text-purple-400 hover:bg-purple-50 dark:hover:bg-purple-900/30 rounded-lg no-underline font-medium">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7" />
                    </svg>
                    ER Diagram
                </a>
                <a href="/export"
                   class="flex items-center gap-2 px-3 py-2 text-sm text-green-600 dark:text-green-400 hover:bg-green-50 dark:hover:bg-green-900/30 rounded-lg no-underline font-medium">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    Export
                </a>
                <a href="/annotations"
                   class="flex items-center gap-2 px-3 py-2 text-sm text-amber-600 dark:text-amber-400 hover:bg-amber-50 dark:hover:bg-amber-900/30 rounded-lg no-underline font-medium">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                    </svg>
                    Annotations
                </a>
                <a href="/diff"
                   class="flex items-center gap-2 px-3 py-2 text-sm text-indigo-600 dark:text-indigo-400 hover:bg-indigo-50 dark:hover:bg-indigo-900/30 rounded-lg no-underline font-medium">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                    </svg>
                    Schema Diff
                </a>
            </div>
        }
    }
</div>

@code {
    private string searchText = "";
    private List<ConnectionProfile> allConnections = [];
    private int? expandedServer;
    private int? loadingDbsId;
    private (int ConnId, string Db)? switchingDb;
    private int? failedId;
    private string? failedMessage;
    private Dictionary<int, IReadOnlyDictionary<string, (string? Tag, string? TagColor)>> dbTagOverrides = new();

    // Inline tag editor state — only one editor open at a time
    private (int ConnId, string Db)? editingTagFor;
    private string? sbEditTag;
    private string sbEditColor = "blue";

    private static readonly (string Name, string Bg)[] tagColorOptions =
    [
        ("green",  "bg-green-500"),
        ("yellow", "bg-yellow-500"),
        ("red",    "bg-red-500"),
        ("blue",   "bg-blue-500"),
        ("purple", "bg-purple-500"),
    ];

    protected override async Task OnInitializedAsync()
    {
        State.OnChanged += OnStateChanged;
        await ReloadConnectionsAsync();
        // Auto-expand the active server if there is one
        if (State.ActiveConnection is not null)
            expandedServer = State.ActiveConnection.Id;
    }

    private async Task ReloadConnectionsAsync()
    {
        allConnections = (await ConnectionRepo.GetAllAsync()).ToList();
        // Refresh tag overrides for visible servers
        foreach (var conn in allConnections)
        {
            dbTagOverrides[conn.Id] = await ConnectionRepo.GetDatabaseTagsAsync(conn.Id);
        }
    }

    private async Task ToggleServerAsync(ConnectionProfile conn)
    {
        // Clear previous error on this server when retrying
        if (failedId == conn.Id) { failedId = null; failedMessage = null; }

        if (expandedServer == conn.Id)
        {
            expandedServer = null;
            return;
        }

        expandedServer = conn.Id;

        // Lazily fetch DB list if we don't have it yet
        if (State.GetCachedDatabaseList(conn.Id) is null)
        {
            loadingDbsId = conn.Id;
            StateHasChanged();
            try
            {
                var dbs = await SchemaLoader.ListDatabasesAsync(conn.Id, conn.Provider);
                State.CacheDatabaseList(conn.Id, dbs);
            }
            catch (Exception ex)
            {
                failedId = conn.Id;
                failedMessage = ex.Message;
                expandedServer = null;
            }
            finally
            {
                loadingDbsId = null;
                StateHasChanged();
            }
        }
    }

    private async Task SwitchToDbAsync(ConnectionProfile conn, string dbName)
    {
        if (State.ActiveConnection?.Id == conn.Id && State.ActiveDatabase == dbName)
        {
            Nav.NavigateTo("/");
            return;
        }

        var (effTag, effColor, _) = ResolveDbTag(conn, dbName);
        var cached = State.GetCachedSchema(conn.Id, dbName);
        if (cached is not null)
        {
            State.SetActiveDatabase(conn, dbName, cached, effTag, effColor);
            Nav.NavigateTo("/");
            return;
        }

        switchingDb = (conn.Id, dbName);
        StateHasChanged();
        try
        {
            var schema = await SchemaLoader.LoadSchemaAsync(conn.Id, conn.Provider, dbName, forceRefresh: false);
            State.SetActiveDatabase(conn, dbName, schema, effTag, effColor);
            await ConnectionRepo.TouchLastConnectedAsync(conn.Id, dbName);
            Nav.NavigateTo("/");
        }
        catch (Exception ex)
        {
            failedId = conn.Id;
            failedMessage = ex.Message;
        }
        finally
        {
            switchingDb = null;
            StateHasChanged();
        }
    }

    private (string? Tag, string? Color, bool HasOverride) ResolveDbTag(ConnectionProfile conn, string dbName)
    {
        if (dbTagOverrides.TryGetValue(conn.Id, out var overrides) &&
            overrides.TryGetValue(dbName, out var ovr))
        {
            // Override (even null tag = explicitly cleared, but our schema doesn't allow that — empty tag = no override)
            return (ovr.Tag, ovr.TagColor, true);
        }
        return (conn.Tag, conn.TagColor, false);
    }

    private void OpenTagEditor(int connId, string dbName)
    {
        // Toggle: if already editing this same row, close
        if (editingTagFor == (connId, dbName))
        {
            CloseTagEditor();
            return;
        }
        editingTagFor = (connId, dbName);
        var conn = allConnections.First(c => c.Id == connId);
        var (effTag, effColor, _) = ResolveDbTag(conn, dbName);
        sbEditTag = effTag;
        sbEditColor = effColor ?? "blue";
    }

    private void CloseTagEditor()
    {
        editingTagFor = null;
        sbEditTag = null;
        sbEditColor = "blue";
    }

    private async Task SaveSidebarTagAsync()
    {
        if (editingTagFor is null) return;
        var (connId, dbName) = editingTagFor.Value;
        var tag = string.IsNullOrWhiteSpace(sbEditTag) ? null : sbEditTag.Trim();
        await ConnectionRepo.UpsertDatabaseTagAsync(connId, dbName, tag, tag is not null ? sbEditColor : null);
        await RefreshOverridesAsync(connId);
        UpdateActiveSessionTagIfNeeded(connId, dbName, tag, tag is not null ? sbEditColor : null);
        CloseTagEditor();
    }

    private async Task ClearSidebarTagAsync()
    {
        if (editingTagFor is null) return;
        var (connId, dbName) = editingTagFor.Value;
        await ConnectionRepo.ClearDatabaseTagAsync(connId, dbName);
        await RefreshOverridesAsync(connId);
        // After clearing, the effective tag falls back to the server's tag
        var conn = allConnections.First(c => c.Id == connId);
        UpdateActiveSessionTagIfNeeded(connId, dbName, conn.Tag, conn.TagColor);
        CloseTagEditor();
    }

    private async Task RefreshOverridesAsync(int connId)
    {
        dbTagOverrides[connId] = await ConnectionRepo.GetDatabaseTagsAsync(connId);
    }

    private void UpdateActiveSessionTagIfNeeded(int connId, string dbName, string? tag, string? color)
    {
        // If the tag the user just edited belongs to the currently active DB, refresh the session state
        // so the rest of the UI (Home page header, etc.) reflects the change immediately.
        if (State.ActiveConnection?.Id == connId && State.ActiveDatabase == dbName && State.CurrentSchema is not null)
        {
            State.SetActiveDatabase(State.ActiveConnection, dbName, State.CurrentSchema, tag, color);
        }
    }

    private IEnumerable<SchemaTable> FilteredTables =>
        State.CurrentSchema?.Tables
            .Where(t => string.IsNullOrWhiteSpace(searchText) ||
                        t.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                        t.Schema.Contains(searchText, StringComparison.OrdinalIgnoreCase))
        ?? Enumerable.Empty<SchemaTable>();

    private IEnumerable<SchemaView> FilteredViews =>
        State.CurrentSchema?.Views
            .Where(v => string.IsNullOrWhiteSpace(searchText) ||
                        v.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase))
        ?? Enumerable.Empty<SchemaView>();

    private IEnumerable<StoredProcedure> FilteredProcs =>
        State.CurrentSchema?.StoredProcedures
            .Where(p => string.IsNullOrWhiteSpace(searchText) ||
                        p.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase))
        ?? Enumerable.Empty<StoredProcedure>();

    private void OnStateChanged() => InvokeAsync(async () =>
    {
        await ReloadConnectionsAsync();
        if (State.ActiveConnection is not null)
            expandedServer = State.ActiveConnection.Id;
        StateHasChanged();
    });

    private void Disconnect()
    {
        State.Clear();
        Nav.NavigateTo("/");
    }

    private async Task TriggerGlobalSearch()
    {
        await JS.InvokeVoidAsync("eval", "document.dispatchEvent(new KeyboardEvent('keydown', {key: 'k', ctrlKey: true}))");
    }

    private static string TagColorClass(string? color) => color switch
    {
        "green"  => "bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-300",
        "yellow" => "bg-yellow-100 dark:bg-yellow-900/40 text-yellow-700 dark:text-yellow-300",
        "red"    => "bg-red-100 dark:bg-red-900/40 text-red-700 dark:text-red-300",
        "blue"   => "bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300",
        "purple" => "bg-purple-100 dark:bg-purple-900/40 text-purple-700 dark:text-purple-300",
        _        => "bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300",
    };

    public void Dispose()
    {
        State.OnChanged -= OnStateChanged;
    }
}
