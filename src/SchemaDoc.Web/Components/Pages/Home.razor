@page "/"
@layout SchemaDoc.Web.Components.Layout.MainLayout
@inject SchemaDoc.Web.Services.SchemaSessionState State
@inject SchemaDoc.Web.Services.SchemaLoaderService SchemaLoader
@inject IConnectionRepository ConnectionRepo
@inject ISchemaSnapshotRepository SnapshotRepo
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>SchemaDoc</PageTitle>

<div class="flex items-center justify-center h-full text-center p-8">
    @if (State.CurrentSchema is null)
    {
        <div>
            <div class="text-6xl mb-4">🗄️</div>
            <h1 class="text-2xl font-bold text-gray-800 dark:text-gray-100 mb-2">Welcome to SchemaDoc</h1>
            <p class="text-gray-500 dark:text-gray-400 mb-6">Connect to a database to start exploring and documenting your schema.</p>
            <a href="/connections"
               class="inline-flex items-center gap-2 bg-blue-600 text-white px-6 py-3 rounded-lg font-medium hover:bg-blue-700 no-underline transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                Add Connection
            </a>
        </div>
    }
    else
    {
        <div class="max-w-xl">
            <div class="text-5xl mb-4">✅</div>
            <div class="flex items-center justify-center gap-2 mb-1 flex-wrap">
                @if (!string.IsNullOrEmpty(State.ActiveDbTag))
                {
                    <span class="@TagColorClass(State.ActiveDbTagColor) text-xs px-2 py-0.5 rounded-full font-semibold">@State.ActiveDbTag</span>
                }
                <h1 class="text-xl font-bold text-gray-800 dark:text-gray-100">@State.CurrentSchema.DatabaseName</h1>
                <button @onclick="ToggleTagEditor"
                        class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 p-1 rounded hover:bg-gray-100 dark:hover:bg-gray-700"
                        title="Edit database tag">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
                    </svg>
                </button>
            </div>

            @if (showTagEditor)
            {
                <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4 mb-4 text-left text-sm">
                    <div class="flex items-center justify-between mb-2">
                        <strong class="text-gray-700 dark:text-gray-200">Tag for this database</strong>
                        <span class="text-xs text-gray-400 dark:text-gray-500">@(hasTagOverride ? "(database-level override)" : "(inherited from server)")</span>
                    </div>
                    <div class="flex flex-wrap items-center gap-1.5 mb-2">
                        @foreach (var preset in new[] { "Dev", "Staging", "Prod", "QA" })
                        {
                            <button type="button" @onclick="() => editTag = (editTag == preset ? null : preset)"
                                    class="text-xs px-2.5 py-1 rounded-full border transition-colors @(editTag == preset ? "bg-blue-100 dark:bg-blue-900/40 border-blue-400 text-blue-700 dark:text-blue-300" : "border-gray-200 dark:border-gray-600 text-gray-500 dark:text-gray-400 hover:border-gray-400")">
                                @preset
                            </button>
                        }
                    </div>
                    <input type="text" @bind="editTag" @bind:event="oninput" placeholder="Or type custom tag..."
                           class="w-full border border-gray-200 dark:border-gray-600 rounded-lg px-3 py-1.5 text-sm bg-white dark:bg-gray-700 text-gray-800 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-300" />
                    <div class="flex items-center gap-2 mt-2">
                        <span class="text-xs text-gray-400 dark:text-gray-500 mr-1">Color:</span>
                        @foreach (var (name, bg) in tagColorOptions)
                        {
                            <button type="button" @onclick="() => editColor = name"
                                    class="w-5 h-5 rounded-full @bg transition-all @(editColor == name ? "ring-2 ring-offset-1 ring-blue-500 dark:ring-offset-gray-800 scale-110" : "opacity-70 hover:opacity-100")">
                            </button>
                        }
                    </div>
                    <div class="flex items-center gap-2 mt-3">
                        <button @onclick="SaveTagOverride"
                                class="bg-blue-600 hover:bg-blue-700 text-white px-3 py-1 rounded text-xs font-medium transition-colors">
                            Save override
                        </button>
                        @if (hasTagOverride)
                        {
                            <button @onclick="ClearTagOverride"
                                    class="text-xs text-gray-500 dark:text-gray-400 hover:text-red-500 dark:hover:text-red-400 px-2 py-1">
                                Clear override (use server tag)
                            </button>
                        }
                        <button @onclick="@(() => { showTagEditor = false; editorOwnerDb = null; })"
                                class="text-xs text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 ml-auto">
                            Close
                        </button>
                    </div>
                </div>
            }

            <p class="text-gray-500 dark:text-gray-400 mb-2">
                @State.CurrentSchema.Tables.Count tables &bull;
                @State.CurrentSchema.Views.Count views &bull;
                @State.CurrentSchema.StoredProcedures.Count procedures &bull;
                @State.CurrentSchema.ForeignKeys.Count relationships
            </p>
            <p class="text-xs text-gray-400 dark:text-gray-500 mb-6">
                Extracted @State.CurrentSchema.ExtractedAt.ToLocalTime().ToString("g")
            </p>

            @if (refreshError is not null)
            {
                <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-300 text-sm rounded-lg px-4 py-3 mb-4">
                    @refreshError
                </div>
            }

            @if (snapshotMessage is not null)
            {
                <div class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 text-green-700 dark:text-green-300 text-sm rounded-lg px-4 py-3 mb-4 flex items-center justify-between">
                    <span>@snapshotMessage</span>
                    <button class="text-green-500 hover:text-green-700" @onclick="() => snapshotMessage = null">×</button>
                </div>
            }

            @if (showSaveSnapshot)
            {
                <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4 mb-4 text-left text-sm">
                    <div class="flex items-center justify-between mb-2">
                        <strong class="text-gray-700 dark:text-gray-200">Save a named snapshot</strong>
                        <span class="text-xs text-gray-400 dark:text-gray-500">Captures the current schema as a durable artifact</span>
                    </div>
                    <p class="text-xs text-gray-500 dark:text-gray-400 mb-3">
                        Named snapshots are kept forever (until manually deleted) and can be diffed against snapshots from any other database — even on a different network.
                    </p>
                    <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-1">Name</label>
                    <input type="text" @bind="snapshotName" @bind:event="oninput" placeholder="e.g. Prod 2026-Q2 baseline"
                           class="w-full border border-gray-200 dark:border-gray-600 rounded-lg px-3 py-1.5 text-sm bg-white dark:bg-gray-700 text-gray-800 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-300 mb-2" />
                    <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-1">Notes (optional)</label>
                    <textarea @bind="snapshotNotes" @bind:event="oninput" rows="2" placeholder="Anything worth remembering about this snapshot…"
                              class="w-full border border-gray-200 dark:border-gray-600 rounded-lg px-3 py-1.5 text-sm bg-white dark:bg-gray-700 text-gray-800 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-300"></textarea>
                    <div class="flex items-center gap-2 mt-3">
                        <button @onclick="SaveSnapshotAsync" disabled="@(savingSnapshot || string.IsNullOrWhiteSpace(snapshotName))"
                                class="bg-blue-600 hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed text-white px-3 py-1 rounded text-xs font-medium transition-colors">
                            @(savingSnapshot ? "Saving…" : "Save Snapshot")
                        </button>
                        <button @onclick="() => showSaveSnapshot = false" class="text-xs text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 ml-auto">
                            Cancel
                        </button>
                    </div>
                </div>
            }

            <!-- Quick actions -->
            <div class="flex flex-wrap gap-3 justify-center mb-6">
                <a href="/diagram"
                   class="inline-flex items-center gap-2 bg-purple-50 dark:bg-gray-700 text-purple-700 dark:text-purple-400 border border-purple-200 dark:border-gray-600 px-4 py-2 rounded-lg text-sm font-medium hover:bg-purple-100 dark:hover:bg-gray-600 no-underline transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7" />
                    </svg>
                    ER Diagram
                </a>
                <a href="/export"
                   class="inline-flex items-center gap-2 bg-green-50 dark:bg-gray-700 text-green-700 dark:text-green-400 border border-green-200 dark:border-gray-600 px-4 py-2 rounded-lg text-sm font-medium hover:bg-green-100 dark:hover:bg-gray-600 no-underline transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    Export PDF
                </a>
                <button class="inline-flex items-center gap-2 bg-gray-50 dark:bg-gray-700 text-gray-700 dark:text-gray-300 border border-gray-200 dark:border-gray-600 px-4 py-2 rounded-lg text-sm font-medium hover:bg-gray-100 dark:hover:bg-gray-600 transition-colors"
                        @onclick="RefreshSchemaAsync" disabled="@refreshing">
                    <svg class="w-4 h-4 @(refreshing ? "animate-spin" : "")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                    </svg>
                    @(refreshing ? "Refreshing..." : "Refresh Schema")
                </button>
                <button class="inline-flex items-center gap-2 bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400 border border-blue-200 dark:border-blue-800 px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-100 dark:hover:bg-blue-900/50 transition-colors"
                        @onclick="ToggleSaveSnapshot" disabled="@savingSnapshot">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M5 13l4 4L19 7" />
                    </svg>
                    Save Snapshot
                </button>
                <a href="/connections"
                   class="inline-flex items-center gap-2 bg-gray-50 dark:bg-gray-700 text-gray-500 dark:text-gray-400 border border-gray-200 dark:border-gray-600 px-4 py-2 rounded-lg text-sm font-medium hover:bg-gray-100 dark:hover:bg-gray-600 no-underline transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                    </svg>
                    Switch Connection
                </a>
            </div>

            <!-- Table overview -->
            <div class="text-left bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4">
                <h3 class="text-sm font-semibold text-gray-500 dark:text-gray-400 mb-2 uppercase tracking-wide">Schemas</h3>
                <div class="flex flex-wrap gap-2">
                    @foreach (var schema in State.CurrentSchema.Tables.Select(t => t.Schema).Distinct().OrderBy(s => s))
                    {
                        var count = State.CurrentSchema.Tables.Count(t => t.Schema == schema);
                        <span class="bg-blue-50 dark:bg-gray-700 text-blue-700 dark:text-blue-300 text-xs px-2.5 py-1 rounded-full font-medium">
                            @schema <span class="text-blue-400 dark:text-blue-400">(@count)</span>
                        </span>
                    }
                </div>
            </div>

            <p class="mt-6 text-sm text-gray-400 dark:text-gray-500">Select a table from the sidebar to start exploring.</p>
        </div>
    }
</div>

@code {
    private bool refreshing;
    private string? refreshError;

    private bool showSaveSnapshot;
    private bool savingSnapshot;
    private string snapshotName = "";
    private string snapshotNotes = "";
    private string? snapshotMessage;

    private bool showTagEditor;
    private string? editTag;
    private string editColor = "blue";
    private bool hasTagOverride;
    // Tracks which DB the editor was opened for, so we can close it when the user switches DBs
    private string? editorOwnerDb;

    private static readonly (string Name, string Bg)[] tagColorOptions =
    [
        ("green",  "bg-green-500"),
        ("yellow", "bg-yellow-500"),
        ("red",    "bg-red-500"),
        ("blue",   "bg-blue-500"),
        ("purple", "bg-purple-500"),
    ];

    private static string TagColorClass(string? color) => color switch
    {
        "green"  => "bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-300",
        "yellow" => "bg-yellow-100 dark:bg-yellow-900/40 text-yellow-700 dark:text-yellow-300",
        "red"    => "bg-red-100 dark:bg-red-900/40 text-red-700 dark:text-red-300",
        "blue"   => "bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300",
        "purple" => "bg-purple-100 dark:bg-purple-900/40 text-purple-700 dark:text-purple-300",
        _        => "bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300",
    };

    protected override async Task OnInitializedAsync()
    {
        State.OnChanged += OnStateChanged;

        // If no active connection but saved connections exist, go straight to the connections list
        if (State.CurrentSchema is null)
        {
            var any = (await ConnectionRepo.GetAllAsync()).Any();
            if (any)
                Nav.NavigateTo("/connections");
        }
        await LoadTagOverrideAsync();
    }

    private void OnStateChanged() => InvokeAsync(async () =>
    {
        // If the user switched to a different database, close the tag editor —
        // its bound fields belonged to the old database.
        if (showTagEditor && editorOwnerDb != State.ActiveDatabase)
        {
            showTagEditor = false;
            editorOwnerDb = null;
        }
        await LoadTagOverrideAsync();
        StateHasChanged();
    });

    private void ToggleTagEditor()
    {
        showTagEditor = !showTagEditor;
        editorOwnerDb = showTagEditor ? State.ActiveDatabase : null;
    }

    private async Task LoadTagOverrideAsync()
    {
        if (State.ActiveConnection is null || State.ActiveDatabase is null)
        {
            hasTagOverride = false;
            return;
        }
        var overrides = await ConnectionRepo.GetDatabaseTagsAsync(State.ActiveConnection.Id);
        if (overrides.TryGetValue(State.ActiveDatabase, out var ovr))
        {
            hasTagOverride = true;
            editTag = ovr.Tag;
            editColor = ovr.TagColor ?? "blue";
        }
        else
        {
            hasTagOverride = false;
            // Pre-fill the editor with the inherited values for convenience
            editTag = State.ActiveConnection.Tag;
            editColor = State.ActiveConnection.TagColor ?? "blue";
        }
    }

    private async Task SaveTagOverride()
    {
        if (State.ActiveConnection is null || State.ActiveDatabase is null) return;
        var tag = string.IsNullOrWhiteSpace(editTag) ? null : editTag.Trim();
        await ConnectionRepo.UpsertDatabaseTagAsync(
            State.ActiveConnection.Id, State.ActiveDatabase, tag, tag is not null ? editColor : null);
        // Update session state so the sidebar reflects the new tag immediately
        State.SetActiveDatabase(State.ActiveConnection, State.ActiveDatabase, State.CurrentSchema!,
            tag, tag is not null ? editColor : null);
        showTagEditor = false;
        editorOwnerDb = null;
        await LoadTagOverrideAsync();
    }

    private async Task ClearTagOverride()
    {
        if (State.ActiveConnection is null || State.ActiveDatabase is null) return;
        await ConnectionRepo.ClearDatabaseTagAsync(State.ActiveConnection.Id, State.ActiveDatabase);
        // Reset to inherited
        State.SetActiveDatabase(State.ActiveConnection, State.ActiveDatabase, State.CurrentSchema!,
            State.ActiveConnection.Tag, State.ActiveConnection.TagColor);
        await LoadTagOverrideAsync();
    }

    private void ToggleSaveSnapshot()
    {
        showSaveSnapshot = !showSaveSnapshot;
        if (showSaveSnapshot)
        {
            snapshotName = "";
            snapshotNotes = "";
            snapshotMessage = null;
        }
    }

    private async Task SaveSnapshotAsync()
    {
        if (State.ActiveConnection is null || State.CurrentSchema is null) return;
        if (string.IsNullOrWhiteSpace(snapshotName)) return;

        savingSnapshot = true;
        try
        {
            // Re-extract live so the named snapshot reflects current DB state, not a possibly stale cache.
            var schema = await SchemaLoader.LoadSchemaAsync(
                State.ActiveConnection.Id, State.ActiveConnection.Provider,
                State.ActiveDatabase, forceRefresh: true);
            State.SetActiveDatabase(State.ActiveConnection, State.ActiveDatabase!, schema,
                State.ActiveDbTag, State.ActiveDbTagColor);

            await SnapshotRepo.SaveAsync(State.ActiveConnection.Id, schema, snapshotName.Trim(), snapshotNotes);
            snapshotMessage = $"Saved snapshot \"{snapshotName.Trim()}\" for {State.ActiveDatabase}.";
            showSaveSnapshot = false;
        }
        catch (Exception ex)
        {
            refreshError = $"Could not save snapshot: {ex.Message}";
        }
        finally
        {
            savingSnapshot = false;
        }
    }

    private async Task RefreshSchemaAsync()
    {
        if (State.ActiveConnection is null || State.ActiveDatabase is null) return;
        refreshing = true;
        refreshError = null;
        try
        {
            var schema = await SchemaLoader.LoadSchemaAsync(
                State.ActiveConnection.Id, State.ActiveConnection.Provider,
                State.ActiveDatabase, forceRefresh: true);
            State.SetActiveDatabase(State.ActiveConnection, State.ActiveDatabase, schema,
                State.ActiveDbTag, State.ActiveDbTagColor);
        }
        catch (Exception ex)
        {
            refreshError = $"Refresh failed: {ex.Message}";
        }
        finally
        {
            refreshing = false;
        }
    }

    public void Dispose()
    {
        State.OnChanged -= OnStateChanged;
    }
}
