@page "/connections"
@layout SchemaDoc.Web.Components.Layout.MainLayout
@inject IConnectionRepository ConnectionRepo
@inject SchemaDoc.Web.Services.SchemaSessionState State
@inject SchemaDoc.Web.Services.SchemaLoaderService SchemaLoader
@inject NavigationManager Nav

<PageTitle>Connections – SchemaDoc</PageTitle>

<div class="p-8 max-w-3xl mx-auto">
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-gray-800 dark:text-gray-100">Connections</h1>
        <button class="flex items-center gap-2 bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors"
                @onclick="ShowAddForm">
            + Add Connection
        </button>
    </div>

    <!-- Connection list -->
    @if (connections.Count == 0 && !showForm)
    {
        <div class="text-center py-12 text-gray-400 dark:text-gray-500">
            <div class="text-4xl mb-3">🔌</div>
            <p>No connections yet. Add one to get started.</p>
        </div>
    }

    @if (errorMessage is not null && !showForm)
    {
        <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-300 text-sm rounded-lg px-4 py-3 mb-4">
            @errorMessage
        </div>
    }

    <div class="space-y-3 mb-6">
        @foreach (var conn in connections)
        {
            var isActive = State.ActiveConnection?.Id == conn.Id;
            <div class="bg-white dark:bg-gray-800 border @(isActive ? "border-blue-300 dark:border-blue-700" : "border-gray-200 dark:border-gray-700") rounded-xl p-4 flex items-center justify-between">
                <div>
                    <div class="flex items-center gap-2">
                        <span class="font-medium text-gray-800 dark:text-gray-100">@conn.Name</span>
                        @if (!string.IsNullOrEmpty(conn.Tag))
                        {
                            <span class="@TagColorClass(conn.TagColor) text-xs px-2 py-0.5 rounded-full font-semibold">@conn.Tag</span>
                        }
                        @if (isActive)
                        {
                            <span class="text-xs bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300 px-2 py-0.5 rounded-full">Active</span>
                        }
                    </div>
                    <div class="text-sm text-gray-400 dark:text-gray-500 flex items-center gap-2 mt-0.5">
                        <span class="bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 px-2 py-0.5 rounded text-xs">@conn.Provider</span>
                        @if (conn.LastDatabaseName is not null)
                        {
                            <span>@conn.LastDatabaseName</span>
                        }
                        <span>Last used @conn.LastConnectedAt.ToLocalTime().ToString("g")</span>
                    </div>
                </div>
                <div class="flex items-center gap-2">
                    <button class="text-sm px-3 py-1.5 rounded-lg transition-colors @(isActive ? "bg-gray-100 dark:bg-gray-700 text-gray-400 dark:text-gray-500 cursor-default" : "bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 hover:bg-blue-100 dark:hover:bg-blue-900/50")"
                            @onclick="() => ConnectAsync(conn)"
                            disabled="@(loading || isActive)">
                        @if (loadingId == conn.Id)
                        {
                            <span>Connecting...</span>
                        }
                        else if (isActive)
                        {
                            <span>Connected</span>
                        }
                        else
                        {
                            <span>Connect</span>
                        }
                    </button>
                    <button class="text-sm text-red-400 hover:text-red-600 dark:text-red-400 dark:hover:text-red-300 px-2 py-1.5 transition-colors"
                            @onclick="() => DeleteAsync(conn.Id)">
                        Delete
                    </button>
                </div>
            </div>
        }
    </div>

    <!-- Add form -->
    @if (showForm)
    {
        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-6">
            <h2 class="text-lg font-semibold text-gray-800 dark:text-gray-100 mb-4">New Connection</h2>

            <div class="space-y-4">
                <!-- Name -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Name</label>
                    <input type="text" @bind="formName" @bind:event="oninput" placeholder="e.g. Production AdventureWorks"
                           class="w-full border border-gray-200 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-800 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-300" />
                </div>

                <!-- Database Type -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Database Type</label>
                    <select @bind="formProvider"
                            class="w-full border border-gray-200 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-300">
                        <option value="@DatabaseProvider.SqlServer">SQL Server</option>
                        <option value="@DatabaseProvider.PostgreSql">PostgreSQL</option>
                        <option value="@DatabaseProvider.MySql">MySQL</option>
                        <option value="@DatabaseProvider.CosmosDb">Azure Cosmos DB</option>
                    </select>
                </div>

                <!-- SQL Server: toggle between structured form and raw paste -->
                @if (formProvider == DatabaseProvider.SqlServer)
                {
                    <div class="flex gap-1 bg-gray-100 dark:bg-gray-900 rounded-lg p-1 w-fit">
                        <button type="button" @onclick="() => sqlUseRawString = false"
                                class="px-3 py-1 rounded-md text-xs font-medium transition-colors @(!sqlUseRawString ? "bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm" : "text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200")">
                            Guided Form
                        </button>
                        <button type="button" @onclick="() => sqlUseRawString = true"
                                class="px-3 py-1 rounded-md text-xs font-medium transition-colors @(sqlUseRawString ? "bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm" : "text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200")">
                            Paste Connection String
                        </button>
                    </div>
                }

                @if (formProvider == DatabaseProvider.SqlServer && sqlUseRawString)
                {
                    <!-- Raw connection string paste for SQL Server -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Connection String</label>
                        <textarea @bind="formConnectionString" @bind:event="oninput" rows="4"
                                  placeholder="Server=myserver.database.windows.net;Database=MyDb;Authentication=Active Directory Interactive;User Id=me@company.com;"
                                  class="w-full border border-gray-200 dark:border-gray-600 rounded-lg px-3 py-2 text-sm font-mono bg-white dark:bg-gray-700 text-gray-800 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-300"></textarea>
                        <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Paste any valid SQL Server connection string. Stored encrypted on your machine. Never sent anywhere.</p>
                    </div>
                }
                else if (formProvider == DatabaseProvider.SqlServer)
                {
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Server</label>
                        <input type="text" @bind="sqlServer" @bind:event="oninput" placeholder="e.g. localhost, myserver.database.windows.net"
                               class="w-full border border-gray-200 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-800 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-300" />
                    </div>

                    @* No Database field: a connection is always a server.
                       The sidebar lets the user pick which database to load after they connect. *@

                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Authentication</label>
                        <select @bind="sqlAuthMethod"
                                class="w-full border border-gray-200 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-300">
                            <option value="SqlAuth">SQL Server Authentication</option>
                            <option value="WindowsAuth">Windows Authentication</option>
                            <option value="AadInteractive">Microsoft Entra MFA (Interactive)</option>
                            <option value="AadPassword">Microsoft Entra Password</option>
                            <option value="AadServicePrincipal">Microsoft Entra Service Principal</option>
                            <option value="AadIntegrated">Microsoft Entra Integrated</option>
                            <option value="AadManagedIdentity">Microsoft Entra Managed Identity</option>
                            <option value="AadDefault">Microsoft Entra Default</option>
                        </select>
                    </div>

                    @if (sqlAuthMethod == "AadInteractive")
                    {
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Username <span class="text-gray-400 font-normal">(optional — leave blank to prompt)</span></label>
                            <input type="text" @bind="sqlUsername" @bind:event="oninput" placeholder="your.email@company.com"
                                   class="w-full border border-gray-200 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-800 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-300" />
                        </div>
                        <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg px-3 py-2 space-y-1">
                            <p class="text-xs text-blue-700 dark:text-blue-300">
                                <strong>How it works:</strong> A browser popup opens to complete Microsoft Entra sign-in (including MFA) when you click <em>Save & Connect</em>. You have 3 minutes to complete it.
                            </p>
                            <p class="text-xs text-amber-700 dark:text-amber-400">
                                <strong>If it fails or times out:</strong> open a terminal, run <code class="bg-amber-100 dark:bg-amber-900/40 px-1 rounded">az login</code>, then switch the auth method above to <strong>Microsoft Entra Default</strong>. No popup needed — it uses your cached Azure CLI token.
                            </p>
                        </div>
                    }

                    @if (sqlAuthMethod is "SqlAuth" or "AadPassword")
                    {
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Username</label>
                            <input type="text" @bind="sqlUsername" @bind:event="oninput" placeholder="e.g. sa"
                                   class="w-full border border-gray-200 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-800 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-300" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Password</label>
                            <input type="password" @bind="sqlPassword" @bind:event="oninput"
                                   class="w-full border border-gray-200 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-300" />
                        </div>
                    }

                    @if (sqlAuthMethod == "AadServicePrincipal")
                    {
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Client ID</label>
                            <input type="text" @bind="sqlUsername" @bind:event="oninput" placeholder="Application (client) ID"
                                   class="w-full border border-gray-200 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-800 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-300" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Client Secret</label>
                            <input type="password" @bind="sqlPassword" @bind:event="oninput"
                                   class="w-full border border-gray-200 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-300" />
                        </div>
                    }

                    <div class="flex items-center gap-2">
                        <input type="checkbox" id="trustCert" @bind="sqlTrustCert"
                               class="rounded border-gray-300 dark:border-gray-600 text-blue-600" />
                        <label for="trustCert" class="text-sm text-gray-700 dark:text-gray-300">Trust Server Certificate</label>
                        <span class="text-xs text-gray-400 dark:text-gray-500">(required for self-signed / dev certs)</span>
                    </div>

                    <!-- Generated connection string preview -->
                    <details class="group">
                        <summary class="text-xs text-gray-400 dark:text-gray-500 cursor-pointer hover:text-gray-600 dark:hover:text-gray-300 select-none">
                            Show generated connection string
                        </summary>
                        <div class="mt-2 font-mono text-xs bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg px-3 py-2 text-gray-600 dark:text-gray-400 break-all">
                            @BuildSqlServerConnectionString()
                        </div>
                    </details>

                    <p class="text-xs text-gray-400 dark:text-gray-500">Stored encrypted on your machine. Never sent anywhere.</p>
                }
                else
                {
                    <!-- Other providers: raw connection string -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Connection String</label>
                        <textarea @bind="formConnectionString" @bind:event="oninput" rows="3"
                                  placeholder="@ConnectionStringPlaceholder"
                                  class="w-full border border-gray-200 dark:border-gray-600 rounded-lg px-3 py-2 text-sm font-mono bg-white dark:bg-gray-700 text-gray-800 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-300"></textarea>
                        <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Stored encrypted on your machine. Never sent anywhere.</p>
                        @if (formProvider == DatabaseProvider.CosmosDb)
                        {
                            <p class="text-xs text-blue-500 dark:text-blue-400 mt-1">
                                Emulator: <span class="font-mono">AccountEndpoint=https://localhost:8081/;AccountKey=C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b5KZzAq/3+1/Ue2HbgL9C5E3D0m3A==;</span>
                            </p>
                        }
                    </div>
                }

                <!-- Environment Tag (optional) -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Environment Tag <span class="text-gray-400 font-normal">(optional)</span></label>
                    <div class="flex items-center gap-2 mb-2">
                        @foreach (var preset in new[] { "Dev", "Staging", "Prod", "QA" })
                        {
                            <button type="button" @onclick="() => formTag = (formTag == preset ? null : preset)"
                                    class="text-xs px-2.5 py-1 rounded-full border transition-colors @(formTag == preset ? "bg-blue-100 dark:bg-blue-900/40 border-blue-400 text-blue-700 dark:text-blue-300" : "border-gray-200 dark:border-gray-600 text-gray-500 dark:text-gray-400 hover:border-gray-400")">
                                @preset
                            </button>
                        }
                    </div>
                    <input type="text" @bind="formTag" @bind:event="oninput" placeholder="Or type custom tag..."
                           class="w-full border border-gray-200 dark:border-gray-600 rounded-lg px-3 py-1.5 text-sm bg-white dark:bg-gray-700 text-gray-800 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-300" />
                    <div class="flex items-center gap-2 mt-2">
                        <span class="text-xs text-gray-400 dark:text-gray-500 mr-1">Color:</span>
                        @foreach (var (name, bg) in tagColorOptions)
                        {
                            <button type="button" @onclick="() => formTagColor = name"
                                    class="w-6 h-6 rounded-full @bg transition-all @(formTagColor == name ? "ring-2 ring-offset-1 ring-blue-500 dark:ring-offset-gray-800 scale-110" : "opacity-70 hover:opacity-100")">
                            </button>
                        }
                    </div>
                </div>

                @if (errorMessage is not null)
                {
                    <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-300 text-sm rounded-lg px-3 py-2">
                        @errorMessage
                    </div>
                }

                <div class="flex gap-3 pt-2">
                    <button class="bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors"
                            @onclick="SaveAsync" disabled="@saving">
                        @(saving ? "Testing..." : "Save & Connect")
                    </button>
                    <button class="text-gray-500 dark:text-gray-400 px-4 py-2 rounded-lg text-sm hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
                            @onclick="() => showForm = false">
                        Cancel
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<ConnectionProfile> connections = [];
    private bool showForm;
    private bool loading;
    private bool saving;
    private int? loadingId;
    private string? errorMessage;

    private string formName = "";
    private DatabaseProvider formProvider = DatabaseProvider.SqlServer;
    private string formConnectionString = "";

    // SQL Server structured fields
    private string sqlServer   = "";
    private string sqlDatabase = "";
    private string sqlAuthMethod = "SqlAuth";
    private string sqlUsername = "";
    private string sqlPassword = "";
    private bool   sqlTrustCert = true;
    private bool   sqlUseRawString; // true = paste mode, false = guided form

    // Tag fields
    private string? formTag;
    private string formTagColor = "blue";

    private static readonly (string Name, string Bg)[] tagColorOptions =
    [
        ("green",  "bg-green-500"),
        ("yellow", "bg-yellow-500"),
        ("red",    "bg-red-500"),
        ("blue",   "bg-blue-500"),
        ("purple", "bg-purple-500"),
    ];

    private static string TagColorClass(string? color) => color switch
    {
        "green"  => "bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-300",
        "yellow" => "bg-yellow-100 dark:bg-yellow-900/40 text-yellow-700 dark:text-yellow-300",
        "red"    => "bg-red-100 dark:bg-red-900/40 text-red-700 dark:text-red-300",
        "blue"   => "bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300",
        "purple" => "bg-purple-100 dark:bg-purple-900/40 text-purple-700 dark:text-purple-300",
        _        => "bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300",
    };

    private string ConnectionStringPlaceholder => formProvider switch
    {
        DatabaseProvider.PostgreSql => "Host=localhost;Port=5432;Database=MyDb;Username=postgres;Password=secret;",
        DatabaseProvider.MySql      => "Server=localhost;Port=3306;Database=MyDb;User=root;Password=secret;",
        DatabaseProvider.CosmosDb   => "AccountEndpoint=https://localhost:8081/;AccountKey=C2y6yDjf5/R+ob0N8...;",
        _                           => "Enter connection string..."
    };

    private string BuildSqlServerConnectionString()
    {
        var trust = sqlTrustCert ? "TrustServerCertificate=True;" : "";
        // Database is optional — if blank, omit it so SqlClient connects to the user's default DB.
        // The sidebar will then enumerate all databases via ListDatabasesAsync.
        var dbPart = string.IsNullOrWhiteSpace(sqlDatabase) ? "" : $"Database={sqlDatabase};";
        // Interactive / MFA: include User Id only if provided (empty causes the login prompt to appear)
        var interactiveUserPart = string.IsNullOrWhiteSpace(sqlUsername) ? "" : $"User Id={sqlUsername};";
        // Give the user 3 minutes to complete MFA in the browser popup (default is 15 seconds)
        const string interactiveTimeout = "Connect Timeout=180;";
        return sqlAuthMethod switch
        {
            "SqlAuth"            => $"Server={sqlServer};{dbPart}User Id={sqlUsername};Password={sqlPassword};{trust}",
            "WindowsAuth"        => $"Server={sqlServer};{dbPart}Integrated Security=True;{trust}",
            "AadInteractive"     => $"Server={sqlServer};{dbPart}Authentication=Active Directory Interactive;{interactiveUserPart}{interactiveTimeout}{trust}",
            "AadPassword"        => $"Server={sqlServer};{dbPart}Authentication=Active Directory Password;User Id={sqlUsername};Password={sqlPassword};{trust}",
            "AadServicePrincipal"=> $"Server={sqlServer};{dbPart}Authentication=Active Directory Service Principal;User Id={sqlUsername};Password={sqlPassword};{trust}",
            "AadIntegrated"      => $"Server={sqlServer};{dbPart}Authentication=Active Directory Integrated;{trust}",
            "AadManagedIdentity" => $"Server={sqlServer};{dbPart}Authentication=Active Directory Managed Identity;{trust}",
            "AadDefault"         => $"Server={sqlServer};{dbPart}Authentication=Active Directory Default;{interactiveTimeout}{trust}",
            _                    => ""
        };
    }

    private string GetEffectiveConnectionString() =>
        formProvider == DatabaseProvider.SqlServer
            ? (sqlUseRawString ? formConnectionString : BuildSqlServerConnectionString())
            : formConnectionString;

    protected override async Task OnInitializedAsync()
    {
        connections = (await ConnectionRepo.GetAllAsync()).ToList();
    }

    private void ShowAddForm()
    {
        showForm      = true;
        errorMessage  = null;
        formName      = "";
        formConnectionString = "";
        formProvider  = DatabaseProvider.SqlServer;
        sqlServer     = "";
        sqlDatabase   = "";
        sqlAuthMethod = "SqlAuth";
        sqlUsername   = "";
        sqlPassword   = "";
        sqlTrustCert  = true;
        sqlUseRawString = false;
        formTag       = null;
        formTagColor  = "blue";
    }

    private async Task SaveAsync()
    {
        var cs = GetEffectiveConnectionString();

        if (string.IsNullOrWhiteSpace(formName) || string.IsNullOrWhiteSpace(cs))
        {
            errorMessage = "Please fill in all required fields.";
            return;
        }

        saving = true;
        errorMessage = null;

        try
        {
            await SchemaLoader.TestConnectionAsync(formProvider, cs);

            var tag = string.IsNullOrWhiteSpace(formTag) ? null : formTag.Trim();
            var id = await ConnectionRepo.AddAsync(formName, formProvider, cs, tag, tag is not null ? formTagColor : null);
            showForm = false;
            connections = (await ConnectionRepo.GetAllAsync()).ToList();

            var profile = connections.First(c => c.Id == id);
            await ConnectAsync(profile);
        }
        catch (Exception ex)
        {
            // Flatten chained exceptions so MSAL / SqlClient inner details are visible
            var messages = new List<string>();
            for (var e = ex; e is not null; e = e.InnerException)
                messages.Add(e.Message);
            errorMessage = string.Join(" → ", messages.Distinct());
        }
        finally
        {
            saving = false;
        }
    }

    private async Task ConnectAsync(ConnectionProfile conn)
    {
        loading = true;
        loadingId = conn.Id;
        errorMessage = null;

        try
        {
            // Discover all databases on this server
            var databases = await SchemaLoader.ListDatabasesAsync(conn.Id, conn.Provider);
            State.CacheDatabaseList(conn.Id, databases);

            // Pick a default DB to load: prefer LastDatabaseName if it still exists, else first
            var defaultDb = databases.FirstOrDefault(d =>
                                d.Equals(conn.LastDatabaseName, StringComparison.OrdinalIgnoreCase))
                            ?? databases.FirstOrDefault();

            if (defaultDb is null)
            {
                // No accessible databases — still navigate home, sidebar will show the server with no DBs
                Nav.NavigateTo("/");
                return;
            }

            var cached = State.GetCachedSchema(conn.Id, defaultDb);
            if (cached is not null)
            {
                State.SetActiveDatabase(conn, defaultDb, cached);
                Nav.NavigateTo("/");
                return;
            }

            var schema = await SchemaLoader.LoadSchemaAsync(conn.Id, conn.Provider, defaultDb, forceRefresh: false);
            State.SetActiveDatabase(conn, defaultDb, schema);
            await ConnectionRepo.TouchLastConnectedAsync(conn.Id, defaultDb);
            Nav.NavigateTo("/");
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load schema: {ex.Message}";
        }
        finally
        {
            loading = false;
            loadingId = null;
        }
    }

    private async Task DeleteAsync(int id)
    {
        if (State.ActiveConnection?.Id == id)
            State.Clear();

        await ConnectionRepo.DeleteAsync(id);
        connections = (await ConnectionRepo.GetAllAsync()).ToList();
    }
}
