@page "/table/{schema}/{tableName}"
@layout SchemaDoc.Web.Components.Layout.MainLayout
@inject SchemaDoc.Web.Services.SchemaSessionState State
@inject IAnnotationRepository AnnotationRepo
@inject NavigationManager Nav

<PageTitle>@TableName – SchemaDoc</PageTitle>

@if (table is null)
{
    <div class="flex items-center justify-center h-full text-gray-400 dark:text-gray-500">
        <p>Table not found. <a href="/" class="text-blue-500 hover:underline">Go home</a></p>
    </div>
}
else
{
    <div class="p-8">
        <!-- Header -->
        <div class="mb-6">
            <div class="flex items-center gap-2 text-sm text-gray-400 dark:text-gray-500 mb-1">
                <span>@Schema</span>
                <span>›</span>
                <span class="font-medium text-gray-700 dark:text-gray-300">@TableName</span>
            </div>
            <div class="flex items-start justify-between">
                <div>
                    <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">@TableName</h1>
                    <p class="text-sm text-gray-400 dark:text-gray-500 mt-0.5">
                        @table.Columns.Count columns
                        @if (table.RowCount.HasValue) { <span> &bull; ~@table.RowCount.Value.ToString("N0") rows</span> }
                    </p>
                </div>
            </div>

            <!-- Table description (editable) -->
            <div class="mt-3">
                @if (editingTableDesc)
                {
                    <div class="flex items-center gap-2">
                        <input type="text" @bind="tableDescValue"
                               class="flex-1 border border-blue-300 dark:border-blue-600 rounded-lg px-3 py-1.5 text-sm bg-white dark:bg-gray-700 text-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-300"
                               placeholder="Add a table description..." />
                        <button class="text-sm bg-blue-600 text-white px-3 py-1.5 rounded-lg hover:bg-blue-700"
                                @onclick="SaveTableDesc">Save</button>
                        <button class="text-sm text-gray-400 dark:text-gray-500 px-2 py-1.5 hover:text-gray-600 dark:hover:text-gray-300"
                                @onclick="() => editingTableDesc = false">Cancel</button>
                    </div>
                }
                else
                {
                    <button class="text-sm text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 flex items-center gap-1 group"
                            @onclick="() => editingTableDesc = true">
                        <span>@(string.IsNullOrWhiteSpace(annotation?.Description) ? "Add description..." : annotation!.Description)</span>
                        <svg class="w-3.5 h-3.5 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                        </svg>
                    </button>
                }
            </div>
        </div>

        <!-- Relationships -->
        @if (inboundFks.Any() || outboundFks.Any())
        {
            <div class="mb-6 flex flex-wrap gap-2">
                @foreach (var fk in outboundFks)
                {
                    <a href="/table/@Uri.EscapeDataString(fk.ReferencedSchema)/@Uri.EscapeDataString(fk.ReferencedTable)"
                       class="inline-flex items-center gap-1 text-xs bg-amber-50 dark:bg-gray-700 text-amber-700 dark:text-amber-400 border border-amber-200 dark:border-gray-600 px-2.5 py-1 rounded-full no-underline hover:bg-amber-100 dark:hover:bg-gray-600 transition-colors">
                        → @fk.ReferencedTable
                        <span class="text-amber-400 dark:text-amber-300">(@fk.ParentColumn)</span>
                    </a>
                }
                @foreach (var fk in inboundFks)
                {
                    <a href="/table/@Uri.EscapeDataString(fk.ParentSchema)/@Uri.EscapeDataString(fk.ParentTable)"
                       class="inline-flex items-center gap-1 text-xs bg-green-50 dark:bg-gray-700 text-green-700 dark:text-green-400 border border-green-200 dark:border-gray-600 px-2.5 py-1 rounded-full no-underline hover:bg-green-100 dark:hover:bg-gray-600 transition-colors">
                        ← @fk.ParentTable
                        <span class="text-green-400 dark:text-green-300">(@fk.ParentColumn)</span>
                    </a>
                }
            </div>
        }

        <!-- Columns table -->
        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl overflow-hidden">
            <table class="w-full text-sm">
                <thead>
                    <tr class="bg-gray-50 dark:bg-gray-900/50 border-b border-gray-200 dark:border-gray-700">
                        <th class="text-left px-4 py-3 font-semibold text-gray-600 dark:text-gray-300 w-8">#</th>
                        <th class="text-left px-4 py-3 font-semibold text-gray-600 dark:text-gray-300">Column</th>
                        <th class="text-left px-4 py-3 font-semibold text-gray-600 dark:text-gray-300">Type</th>
                        <th class="text-left px-4 py-3 font-semibold text-gray-600 dark:text-gray-300 w-16">Null</th>
                        <th class="text-left px-4 py-3 font-semibold text-gray-600 dark:text-gray-300">Description</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var col in table.Columns)
                    {
                        var colAnnotation = GetColumnAnnotation(col.Name);
                        <tr class="border-b border-gray-100 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700/30 transition-colors">
                            <!-- Position -->
                            <td class="px-4 py-3 text-gray-300 dark:text-gray-600 text-xs">@col.OrdinalPosition</td>

                            <!-- Name + badges -->
                            <td class="px-4 py-3">
                                <div class="flex items-center gap-1.5">
                                    @if (col.IsPrimaryKey)
                                    {
                                        <span title="Primary Key" class="text-yellow-500 text-xs">🔑</span>
                                    }
                                    @if (col.IsForeignKey && !col.IsPrimaryKey)
                                    {
                                        <span title="Foreign Key" class="text-blue-400 text-xs">🔗</span>
                                    }
                                    @if (col.IsIdentity)
                                    {
                                        <span class="bg-purple-50 dark:bg-purple-900/30 text-purple-600 dark:text-purple-400 text-xs px-1.5 py-0.5 rounded">AI</span>
                                    }
                                    <span class="font-medium text-gray-800 dark:text-gray-100">@col.Name</span>
                                </div>
                            </td>

                            <!-- Type -->
                            <td class="px-4 py-3">
                                <span class="font-mono text-xs bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 px-2 py-0.5 rounded">
                                    @col.DataType@(col.MaxLength is not null ? $"({col.MaxLength})" : "")
                                </span>
                            </td>

                            <!-- Nullable -->
                            <td class="px-4 py-3 text-center">
                                @if (col.IsNullable)
                                {
                                    <span class="text-gray-300 dark:text-gray-600 text-xs">NULL</span>
                                }
                                else
                                {
                                    <span class="text-red-400 text-xs font-medium">NOT NULL</span>
                                }
                            </td>

                            <!-- Description (editable) -->
                            <td class="px-4 py-3">
                                <ColumnDescriptionCell
                                    ColumnName="@col.Name"
                                    InitialDescription="@(colAnnotation ?? col.DbNativeComment)"
                                    OnSave="EventCallback.Factory.Create<string?>(this, (desc) => SaveColumnDesc(col.Name, desc))" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    [Parameter] public string Schema { get; set; } = "";
    [Parameter] public string TableName { get; set; } = "";

    private SchemaTable? table;
    private TableAnnotationDto? annotation;
    private List<ForeignKeyRelation> outboundFks = [];
    private List<ForeignKeyRelation> inboundFks = [];

    private bool editingTableDesc;
    private string tableDescValue = "";

    protected override async Task OnParametersSetAsync()
    {
        table = State.CurrentSchema?.Tables
            .FirstOrDefault(t =>
                string.Equals(t.Schema, Schema, StringComparison.OrdinalIgnoreCase) &&
                string.Equals(t.Name, TableName, StringComparison.OrdinalIgnoreCase));

        if (table is null || State.ActiveConnection is null || State.CurrentSchema is null) return;

        annotation = await AnnotationRepo.GetTableAnnotationAsync(
            State.ActiveConnection.Name, State.CurrentSchema.DatabaseName, Schema, TableName);
        tableDescValue = annotation?.Description ?? "";

        outboundFks = State.CurrentSchema.ForeignKeys
            .Where(f => string.Equals(f.ParentTable, TableName, StringComparison.OrdinalIgnoreCase))
            .ToList();

        inboundFks = State.CurrentSchema.ForeignKeys
            .Where(f => string.Equals(f.ReferencedTable, TableName, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private string? GetColumnAnnotation(string columnName) =>
        annotation?.ColumnAnnotations
            .FirstOrDefault(c => string.Equals(c.ColumnName, columnName, StringComparison.OrdinalIgnoreCase))
            ?.Description;

    private async Task SaveTableDesc()
    {
        if (State.ActiveConnection is null || State.CurrentSchema is null) return;

        var dto = new TableAnnotationDto(
            ConnectionName: State.ActiveConnection.Name,
            DatabaseName: State.CurrentSchema.DatabaseName,
            SchemaName: Schema,
            TableName: TableName,
            Description: tableDescValue,
            Tags: annotation?.Tags,
            ColumnAnnotations: annotation?.ColumnAnnotations ?? []
        );

        await AnnotationRepo.UpsertTableAnnotationAsync(dto);
        annotation = await AnnotationRepo.GetTableAnnotationAsync(
            State.ActiveConnection.Name, State.CurrentSchema.DatabaseName, Schema, TableName);
        editingTableDesc = false;
    }

    private async Task SaveColumnDesc(string columnName, string? description)
    {
        if (State.ActiveConnection is null || State.CurrentSchema is null) return;

        await AnnotationRepo.UpsertColumnAnnotationAsync(
            State.ActiveConnection.Name, State.CurrentSchema.DatabaseName,
            Schema, TableName, columnName, description);

        annotation = await AnnotationRepo.GetTableAnnotationAsync(
            State.ActiveConnection.Name, State.CurrentSchema.DatabaseName, Schema, TableName);
    }
}
