@page "/diff"
@layout SchemaDoc.Web.Components.Layout.MainLayout
@using SchemaDoc.Core.Services.Migration
@inject SchemaDoc.Web.Services.SchemaSessionState SessionState
@inject ISchemaSnapshotRepository SnapshotRepo
@inject IConnectionRepository ConnectionRepo
@inject SchemaDoc.Core.Services.SchemaDiffService DiffService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Schema Diff - SchemaDoc</PageTitle>

<div class="p-8 max-w-4xl mx-auto">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-2">Schema Diff</h1>
    <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">
        Compare any two snapshots — same database over time, or different databases (even on different networks).
    </p>

    @if (allSnapshots.Count < 2)
    {
        <div class="text-center py-16 text-gray-400">
            <div class="text-5xl mb-4">📸</div>
            <p class="text-lg mb-2">Need at least 2 snapshots</p>
            <p class="text-sm max-w-md mx-auto">
                Connect to a database and click <strong>Save Snapshot</strong> on the
                <a href="/" class="text-blue-500 hover:underline">home page</a>
                to capture one. To diff databases on different networks, save a named snapshot of each, then come back here.
            </p>
            <p class="mt-3 text-xs text-gray-400 dark:text-gray-500">
                Currently @allSnapshots.Count snapshot(s) stored.
            </p>
        </div>
    }
    else
    {
        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-6 mb-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                @* ── Baseline side ───────────────────────────────────── *@
                <div class="space-y-2">
                    <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">Baseline</label>

                    <select class="w-full border border-gray-200 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-800 dark:text-gray-100"
                            @onchange="@(e => OnSideConnectionChanged(true, int.Parse(e.Value!.ToString()!)))">
                        @foreach (var conn in connectionOptions)
                        {
                            <option value="@conn.Id" selected="@(conn.Id == baselineConnId)">
                                @if (!string.IsNullOrEmpty(conn.Tag)) { @($"[{conn.Tag}] ") }@conn.Name
                            </option>
                        }
                    </select>

                    <select class="w-full border border-gray-200 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-800 dark:text-gray-100"
                            @onchange="@(e => OnSideDatabaseChanged(true, e.Value?.ToString() ?? ""))"
                            disabled="@(baselineDbOptions.Count == 0)">
                        @if (baselineDbOptions.Count == 0)
                        {
                            <option value="">(no snapshots for this connection)</option>
                        }
                        @foreach (var db in baselineDbOptions)
                        {
                            <option value="@db" selected="@(db == baselineDb)">@db</option>
                        }
                    </select>

                    <select class="w-full border border-gray-200 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-800 dark:text-gray-100"
                            @bind="baselineSnapshotId"
                            disabled="@(baselineSnapshotOptions.Count == 0)">
                        @if (baselineSnapshotOptions.Count == 0)
                        {
                            <option value="0">(no snapshots for this database)</option>
                        }
                        @foreach (var snap in baselineSnapshotOptions)
                        {
                            <option value="@snap.Id">@FormatSnapshotLabel(snap)</option>
                        }
                    </select>
                </div>

                @* ── Compare side ───────────────────────────────────── *@
                <div class="space-y-2">
                    <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">Compare To</label>

                    <select class="w-full border border-gray-200 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-800 dark:text-gray-100"
                            @onchange="@(e => OnSideConnectionChanged(false, int.Parse(e.Value!.ToString()!)))">
                        @foreach (var conn in connectionOptions)
                        {
                            <option value="@conn.Id" selected="@(conn.Id == compareConnId)">
                                @if (!string.IsNullOrEmpty(conn.Tag)) { @($"[{conn.Tag}] ") }@conn.Name
                            </option>
                        }
                    </select>

                    <select class="w-full border border-gray-200 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-800 dark:text-gray-100"
                            @onchange="@(e => OnSideDatabaseChanged(false, e.Value?.ToString() ?? ""))"
                            disabled="@(compareDbOptions.Count == 0)">
                        @if (compareDbOptions.Count == 0)
                        {
                            <option value="">(no snapshots for this connection)</option>
                        }
                        @foreach (var db in compareDbOptions)
                        {
                            <option value="@db" selected="@(db == compareDb)">@db</option>
                        }
                    </select>

                    <select class="w-full border border-gray-200 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-800 dark:text-gray-100"
                            @bind="compareSnapshotId"
                            disabled="@(compareSnapshotOptions.Count == 0)">
                        @if (compareSnapshotOptions.Count == 0)
                        {
                            <option value="0">(no snapshots for this database)</option>
                        }
                        @foreach (var snap in compareSnapshotOptions)
                        {
                            <option value="@snap.Id">@FormatSnapshotLabel(snap)</option>
                        }
                    </select>
                </div>
            </div>

            <p class="mt-4 text-xs text-gray-400 dark:text-gray-500">
                Diff runs entirely from saved snapshots — no live database connection needed. Manage snapshots on the
                <a href="/snapshots" class="text-blue-500 hover:underline">Snapshots</a> page.
            </p>
            <div class="mt-4">
                <button class="flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2 rounded-lg text-sm font-medium transition-colors disabled:opacity-50"
                        @onclick="RunDiff" disabled="@(running || baselineSnapshotId == 0 || compareSnapshotId == 0)">
                    @(running ? "Comparing..." : "Compare Snapshots")
                </button>
            </div>
        </div>
    }

    @if (errorMessage is not null)
    {
        <div class="bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-700 text-red-700 dark:text-red-300 text-sm rounded-lg px-4 py-2 mb-4">@errorMessage</div>
    }

    @if (diffResult is not null)
    {
        @if (diffLabels is not null)
        {
            <div class="flex items-center gap-2 mb-4 text-xs text-gray-500 dark:text-gray-400">
                <span class="font-medium text-gray-700 dark:text-gray-200">@diffLabels.Value.Baseline</span>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                <span class="font-medium text-gray-700 dark:text-gray-200">@diffLabels.Value.Compare</span>
            </div>
        }

        @if (diffResult.IsIdentical)
        {
            <div class="bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-700 rounded-xl p-8 text-center">
                <div class="text-4xl mb-3">✅</div>
                <p class="text-green-700 dark:text-green-300 font-semibold text-lg">Schemas are identical</p>
                <p class="text-sm text-green-600 dark:text-green-400 mt-1">No differences found.</p>
            </div>
        }
        else
        {
            <!-- Summary badges -->
            <div class="flex flex-wrap gap-3 mb-4 text-sm">
                @if (diffResult.AddedTables.Count > 0)
                {
                    <span class="bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-300 px-3 py-1 rounded-full font-medium">+@diffResult.AddedTables.Count table(s) added</span>
                }
                @if (diffResult.RemovedTables.Count > 0)
                {
                    <span class="bg-red-100 dark:bg-red-900/40 text-red-700 dark:text-red-300 px-3 py-1 rounded-full font-medium">-@diffResult.RemovedTables.Count table(s) removed</span>
                }
                @if (diffResult.ModifiedTables.Count > 0)
                {
                    <span class="bg-amber-100 dark:bg-amber-900/40 text-amber-700 dark:text-amber-300 px-3 py-1 rounded-full font-medium">~@diffResult.ModifiedTables.Count table(s) modified</span>
                }
                @if ((diffResult.AddedTriggers?.Count ?? 0) + (diffResult.RemovedTriggers?.Count ?? 0) + (diffResult.ModifiedTriggers?.Count ?? 0) > 0)
                {
                    <span class="bg-indigo-100 dark:bg-indigo-900/40 text-indigo-700 dark:text-indigo-300 px-3 py-1 rounded-full font-medium">@((diffResult.AddedTriggers?.Count ?? 0) + (diffResult.RemovedTriggers?.Count ?? 0) + (diffResult.ModifiedTriggers?.Count ?? 0)) trigger(s) changed</span>
                }
            </div>

            @if (diffResult.AddedTables.Count > 0)
            {
                <div class="bg-white dark:bg-gray-800 border border-green-200 dark:border-green-800 rounded-xl mb-4 overflow-hidden">
                    <div class="bg-green-50 dark:bg-green-900/30 px-4 py-3 border-b border-green-100 dark:border-green-800">
                        <h2 class="text-sm font-semibold text-green-700 dark:text-green-300">Added Tables (@diffResult.AddedTables.Count)</h2>
                        <p class="text-xs text-green-600 dark:text-green-500 mt-0.5">Present in compare, missing from baseline</p>
                    </div>
                    <div class="divide-y divide-gray-100 dark:divide-gray-700">
                        @foreach (var table in diffResult.AddedTables)
                        {
                            <div class="px-4 py-3 flex items-center justify-between">
                                <span class="text-sm font-medium text-gray-800 dark:text-gray-100">@table.FullName</span>
                                <span class="text-xs text-gray-400 dark:text-gray-500">@table.Columns.Count columns</span>
                            </div>
                        }
                    </div>
                </div>
            }

            @if (diffResult.RemovedTables.Count > 0)
            {
                <div class="bg-white dark:bg-gray-800 border border-red-200 dark:border-red-800 rounded-xl mb-4 overflow-hidden">
                    <div class="bg-red-50 dark:bg-red-900/30 px-4 py-3 border-b border-red-100 dark:border-red-800">
                        <h2 class="text-sm font-semibold text-red-700 dark:text-red-300">Removed Tables (@diffResult.RemovedTables.Count)</h2>
                        <p class="text-xs text-red-600 dark:text-red-500 mt-0.5">Present in baseline, missing from compare</p>
                    </div>
                    <div class="divide-y divide-gray-100 dark:divide-gray-700">
                        @foreach (var table in diffResult.RemovedTables)
                        {
                            <div class="px-4 py-3 flex items-center justify-between">
                                <span class="text-sm font-medium text-gray-800 dark:text-gray-100">@table.FullName</span>
                                <span class="text-xs text-gray-400 dark:text-gray-500">@table.Columns.Count columns</span>
                            </div>
                        }
                    </div>
                </div>
            }

            @if (diffResult.ModifiedTables.Count > 0)
            {
                <div class="bg-white dark:bg-gray-800 border border-amber-200 dark:border-amber-800 rounded-xl overflow-hidden">
                    <div class="bg-amber-50 dark:bg-amber-900/30 px-4 py-3 border-b border-amber-100 dark:border-amber-800">
                        <h2 class="text-sm font-semibold text-amber-700 dark:text-amber-300">Modified Tables (@diffResult.ModifiedTables.Count)</h2>
                        <p class="text-xs text-amber-600 dark:text-amber-500 mt-0.5">Same table name, different columns or types</p>
                    </div>
                    <div class="divide-y divide-gray-100 dark:divide-gray-700">
                        @foreach (var table in diffResult.ModifiedTables)
                        {
                            <details>
                                <summary class="px-4 py-3 flex items-center justify-between cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-700/50 list-none select-none">
                                    <span class="text-sm font-medium text-gray-800 dark:text-gray-100">@table.FullName</span>
                                    <span class="text-xs text-amber-600 dark:text-amber-400 font-medium">@table.TotalChanges change(s) ▾</span>
                                </summary>
                                <div class="px-6 pb-4 pt-1 space-y-2">
                                    @* Column changes *@
                                    @if (table.AddedColumns.Count + table.RemovedColumns.Count + table.ModifiedColumns.Count > 0)
                                    {
                                        <div class="space-y-1">
                                            <div class="text-[11px] font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">Columns</div>
                                            @foreach (var col in table.AddedColumns)
                                            {
                                                <div class="text-xs text-green-600 dark:text-green-400">
                                                    <span class="font-bold">+</span> <span class="font-medium">@col.Name</span>
                                                    <span class="text-green-500 dark:text-green-500">(@col.DataType)</span> — added
                                                </div>
                                            }
                                            @foreach (var col in table.RemovedColumns)
                                            {
                                                <div class="text-xs text-red-600 dark:text-red-400">
                                                    <span class="font-bold">-</span> <span class="font-medium">@col.Name</span>
                                                    <span class="text-red-500 dark:text-red-500">(@col.DataType)</span> — removed
                                                </div>
                                            }
                                            @foreach (var colDiff in table.ModifiedColumns)
                                            {
                                                foreach (var change in colDiff.Changes)
                                                {
                                                    <div class="text-xs text-amber-600 dark:text-amber-400">
                                                        <span class="font-bold">~</span> <span class="font-medium">@colDiff.ColumnName</span> — @change
                                                    </div>
                                                }
                                            }
                                        </div>
                                    }

                                    @* Primary Key changes *@
                                    @if (table.PrimaryKeyChanges is not null && table.PrimaryKeyChanges.Count > 0)
                                    {
                                        <div class="space-y-1">
                                            <div class="text-[11px] font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">Primary Key</div>
                                            @foreach (var change in table.PrimaryKeyChanges)
                                            {
                                                <div class="text-xs text-amber-600 dark:text-amber-400">
                                                    <span class="font-bold">~</span> @change
                                                </div>
                                            }
                                        </div>
                                    }

                                    @* Indexes *@
                                    @{
                                        var hasIdx = (table.AddedIndexes?.Count ?? 0) + (table.RemovedIndexes?.Count ?? 0) + (table.ModifiedIndexes?.Count ?? 0) > 0;
                                    }
                                    @if (hasIdx)
                                    {
                                        <div class="space-y-1">
                                            <div class="text-[11px] font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">Indexes</div>
                                            @if (table.AddedIndexes is not null)
                                            {
                                                foreach (var ix in table.AddedIndexes)
                                                {
                                                    <div class="text-xs text-green-600 dark:text-green-400">
                                                        <span class="font-bold">+</span> <span class="font-medium">@ix.Name</span>
                                                        <span class="text-green-500 dark:text-green-500">(@(string.Join(", ", ix.Columns.Select(c => c.IsDescending ? c.Name + " DESC" : c.Name))))</span>
                                                        @if (ix.IsUnique)
                                                        {
                                                            <span class="text-[10px] ml-1 px-1 rounded bg-green-100 dark:bg-green-900/40">UNIQUE</span>
                                                        }
                                                        @if (!string.IsNullOrEmpty(ix.IndexType))
                                                        {
                                                            <span class="text-[10px] ml-1 text-green-500 dark:text-green-500">@ix.IndexType</span>
                                                        }
                                                    </div>
                                                }
                                            }
                                            @if (table.RemovedIndexes is not null)
                                            {
                                                foreach (var ix in table.RemovedIndexes)
                                                {
                                                    <div class="text-xs text-red-600 dark:text-red-400">
                                                        <span class="font-bold">-</span> <span class="font-medium">@ix.Name</span>
                                                        <span class="text-red-500 dark:text-red-500">(@(string.Join(", ", ix.Columns.Select(c => c.Name))))</span>
                                                    </div>
                                                }
                                            }
                                            @if (table.ModifiedIndexes is not null)
                                            {
                                                foreach (var ixDiff in table.ModifiedIndexes)
                                                {
                                                    foreach (var change in ixDiff.Changes)
                                                    {
                                                        <div class="text-xs text-amber-600 dark:text-amber-400">
                                                            <span class="font-bold">~</span> <span class="font-medium">@ixDiff.Name</span> — @change
                                                        </div>
                                                    }
                                                }
                                            }
                                        </div>
                                    }

                                    @* Unique Constraints *@
                                    @{
                                        var hasUq = (table.AddedUniqueConstraints?.Count ?? 0) + (table.RemovedUniqueConstraints?.Count ?? 0) + (table.ModifiedUniqueConstraints?.Count ?? 0) > 0;
                                    }
                                    @if (hasUq)
                                    {
                                        <div class="space-y-1">
                                            <div class="text-[11px] font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">Unique Constraints</div>
                                            @if (table.AddedUniqueConstraints is not null)
                                            {
                                                foreach (var uq in table.AddedUniqueConstraints)
                                                {
                                                    <div class="text-xs text-green-600 dark:text-green-400">
                                                        <span class="font-bold">+</span> <span class="font-medium">@uq.Name</span>
                                                        <span class="text-green-500 dark:text-green-500">(@(string.Join(", ", uq.Columns)))</span>
                                                    </div>
                                                }
                                            }
                                            @if (table.RemovedUniqueConstraints is not null)
                                            {
                                                foreach (var uq in table.RemovedUniqueConstraints)
                                                {
                                                    <div class="text-xs text-red-600 dark:text-red-400">
                                                        <span class="font-bold">-</span> <span class="font-medium">@uq.Name</span>
                                                        <span class="text-red-500 dark:text-red-500">(@(string.Join(", ", uq.Columns)))</span>
                                                    </div>
                                                }
                                            }
                                            @if (table.ModifiedUniqueConstraints is not null)
                                            {
                                                foreach (var uqDiff in table.ModifiedUniqueConstraints)
                                                {
                                                    foreach (var change in uqDiff.Changes)
                                                    {
                                                        <div class="text-xs text-amber-600 dark:text-amber-400">
                                                            <span class="font-bold">~</span> <span class="font-medium">@uqDiff.Name</span> — @change
                                                        </div>
                                                    }
                                                }
                                            }
                                        </div>
                                    }

                                    @* Check Constraints *@
                                    @{
                                        var hasCk = (table.AddedCheckConstraints?.Count ?? 0) + (table.RemovedCheckConstraints?.Count ?? 0) + (table.ModifiedCheckConstraints?.Count ?? 0) > 0;
                                    }
                                    @if (hasCk)
                                    {
                                        <div class="space-y-1">
                                            <div class="text-[11px] font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">Check Constraints</div>
                                            @if (table.AddedCheckConstraints is not null)
                                            {
                                                foreach (var ck in table.AddedCheckConstraints)
                                                {
                                                    <div class="text-xs text-green-600 dark:text-green-400">
                                                        <span class="font-bold">+</span> <span class="font-medium">@ck.Name</span>
                                                        <span class="text-green-500 dark:text-green-500 font-mono">@ck.Expression</span>
                                                    </div>
                                                }
                                            }
                                            @if (table.RemovedCheckConstraints is not null)
                                            {
                                                foreach (var ck in table.RemovedCheckConstraints)
                                                {
                                                    <div class="text-xs text-red-600 dark:text-red-400">
                                                        <span class="font-bold">-</span> <span class="font-medium">@ck.Name</span>
                                                    </div>
                                                }
                                            }
                                            @if (table.ModifiedCheckConstraints is not null)
                                            {
                                                foreach (var ckDiff in table.ModifiedCheckConstraints)
                                                {
                                                    foreach (var change in ckDiff.Changes)
                                                    {
                                                        <div class="text-xs text-amber-600 dark:text-amber-400">
                                                            <span class="font-bold">~</span> <span class="font-medium">@ckDiff.Name</span> — @change
                                                        </div>
                                                    }
                                                }
                                            }
                                        </div>
                                    }

                                    @* Foreign Keys *@
                                    @{
                                        var hasFk = (table.AddedForeignKeys?.Count ?? 0) + (table.RemovedForeignKeys?.Count ?? 0) + (table.ModifiedForeignKeys?.Count ?? 0) > 0;
                                    }
                                    @if (hasFk)
                                    {
                                        <div class="space-y-1">
                                            <div class="text-[11px] font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">Foreign Keys</div>
                                            @if (table.AddedForeignKeys is not null)
                                            {
                                                foreach (var fk in table.AddedForeignKeys)
                                                {
                                                    <div class="text-xs text-green-600 dark:text-green-400">
                                                        <span class="font-bold">+</span> <span class="font-medium">@fk.ConstraintName</span>
                                                        <span class="text-green-500 dark:text-green-500">(@(string.Join(", ", fk.ParentColumns))) → @(fk.ReferencedSchema + "." + fk.ReferencedTable)(@(string.Join(", ", fk.ReferencedColumns)))</span>
                                                    </div>
                                                }
                                            }
                                            @if (table.RemovedForeignKeys is not null)
                                            {
                                                foreach (var fk in table.RemovedForeignKeys)
                                                {
                                                    <div class="text-xs text-red-600 dark:text-red-400">
                                                        <span class="font-bold">-</span> <span class="font-medium">@fk.ConstraintName</span>
                                                    </div>
                                                }
                                            }
                                            @if (table.ModifiedForeignKeys is not null)
                                            {
                                                foreach (var fkDiff in table.ModifiedForeignKeys)
                                                {
                                                    foreach (var change in fkDiff.Changes)
                                                    {
                                                        <div class="text-xs text-amber-600 dark:text-amber-400">
                                                            <span class="font-bold">~</span> <span class="font-medium">@fkDiff.Name</span> — @change
                                                        </div>
                                                    }
                                                }
                                            }
                                        </div>
                                    }
                                </div>
                            </details>
                        }
                    </div>
                </div>
            }

            @* ── Triggers ──────────────────────────────────────────── *@
            @if ((diffResult.AddedTriggers?.Count ?? 0) + (diffResult.RemovedTriggers?.Count ?? 0) + (diffResult.ModifiedTriggers?.Count ?? 0) > 0)
            {
                <div class="bg-white dark:bg-gray-800 border border-indigo-200 dark:border-indigo-800 rounded-xl mt-4 overflow-hidden">
                    <div class="bg-indigo-50 dark:bg-indigo-900/30 px-4 py-3 border-b border-indigo-100 dark:border-indigo-800">
                        <h2 class="text-sm font-semibold text-indigo-700 dark:text-indigo-300">Triggers</h2>
                        <p class="text-xs text-indigo-600 dark:text-indigo-500 mt-0.5">Database-level trigger differences</p>
                    </div>
                    <div class="px-6 py-3 space-y-1.5">
                        @if (diffResult.AddedTriggers is not null)
                        {
                            foreach (var trg in diffResult.AddedTriggers)
                            {
                                <div class="text-xs text-green-600 dark:text-green-400">
                                    <span class="font-bold">+</span> <span class="font-medium">@trg.FullName</span>
                                    <span class="text-green-500 dark:text-green-500">on @trg.TableSchema.@trg.TableName · @trg.Timing @trg.Event</span>
                                </div>
                            }
                        }
                        @if (diffResult.RemovedTriggers is not null)
                        {
                            foreach (var trg in diffResult.RemovedTriggers)
                            {
                                <div class="text-xs text-red-600 dark:text-red-400">
                                    <span class="font-bold">-</span> <span class="font-medium">@trg.FullName</span>
                                    <span class="text-red-500 dark:text-red-500">on @trg.TableSchema.@trg.TableName</span>
                                </div>
                            }
                        }
                        @if (diffResult.ModifiedTriggers is not null)
                        {
                            foreach (var trgDiff in diffResult.ModifiedTriggers)
                            {
                                foreach (var change in trgDiff.Changes)
                                {
                                    <div class="text-xs text-amber-600 dark:text-amber-400">
                                        <span class="font-bold">~</span> <span class="font-medium">@trgDiff.FullName</span> — @change
                                    </div>
                                }
                            }
                        }
                    </div>
                </div>
            }

            @* ─── Migration Script Generator ────────────────────── *@
            @if (!diffResult.IsIdentical && canGenerateScript)
            {
                <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl mt-6 overflow-hidden">
                    <div class="bg-gradient-to-r from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 px-4 py-3 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between">
                        <div>
                            <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-100">Migration Script</h2>
                            <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">Generate SQL to apply these changes</p>
                        </div>
                        @if (!scriptPanelOpen)
                        {
                            <button class="text-sm bg-blue-600 hover:bg-blue-700 text-white px-4 py-1.5 rounded-lg font-medium transition-colors"
                                    @onclick="OpenScriptPanel">
                                Generate Migration Script
                            </button>
                        }
                    </div>

                    @if (scriptPanelOpen)
                    {
                        <div class="p-4 space-y-4">
                            <!-- Direction selector -->
                            <div>
                                <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-1">Direction</label>
                                <div class="flex items-center gap-2 text-sm flex-wrap">
                                    <button class="px-3 py-1.5 rounded-lg border transition-colors @(scriptDirection == ScriptDirection.BaselineToTarget ? "border-blue-400 bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 font-medium" : "border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400")"
                                            @onclick="() => SetDirection(ScriptDirection.BaselineToTarget)">
                                        Apply to @GetLabel(true) → match @GetLabel(false)
                                    </button>
                                    <button class="px-3 py-1.5 rounded-lg border transition-colors @(scriptDirection == ScriptDirection.TargetToBaseline ? "border-blue-400 bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 font-medium" : "border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400")"
                                            @onclick="() => SetDirection(ScriptDirection.TargetToBaseline)">
                                        Apply to @GetLabel(false) → match @GetLabel(true)
                                    </button>
                                </div>
                            </div>

                            <!-- Action checkboxes -->
                            @if (migrationActions.Count > 0)
                            {
                                <div>
                                    <div class="flex items-center justify-between mb-2">
                                        <label class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">Changes to Include (@selectedActionIds.Count / @migrationActions.Count)</label>
                                        <div class="flex items-center gap-2">
                                            <button class="text-xs text-blue-600 dark:text-blue-400 hover:underline" @onclick="SelectAllActions">Select all</button>
                                            <span class="text-gray-300 dark:text-gray-600">·</span>
                                            <button class="text-xs text-blue-600 dark:text-blue-400 hover:underline" @onclick="DeselectAllActions">Deselect all</button>
                                        </div>
                                    </div>
                                    <div class="max-h-72 overflow-y-auto border border-gray-200 dark:border-gray-700 rounded-lg divide-y divide-gray-100 dark:divide-gray-700">
                                        @foreach (var group in migrationActions.GroupBy(a => a.Category))
                                        {
                                            <div>
                                                <div class="px-3 py-1.5 bg-gray-50 dark:bg-gray-900/50 text-[11px] font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">
                                                    @group.Key (@group.Count())
                                                </div>
                                                @foreach (var action in group)
                                                {
                                                    var actionId = action.Id;
                                                    <label class="flex items-start gap-2 px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer">
                                                        <input type="checkbox" class="mt-0.5 flex-shrink-0"
                                                               checked="@selectedActionIds.Contains(actionId)"
                                                               @onchange="@(e => ToggleAction(actionId, (bool)e.Value!))" />
                                                        <div class="text-xs min-w-0 flex-1">
                                                            <div class="text-gray-800 dark:text-gray-200 truncate">@action.Description</div>
                                                            <div class="text-[10px] text-gray-400 dark:text-gray-500 font-mono mt-0.5">@action.TableFullName</div>
                                                        </div>
                                                    </label>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            }

                            <div class="flex items-center gap-2">
                                <button class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-1.5 rounded-lg text-sm font-medium transition-colors disabled:opacity-50"
                                        @onclick="GenerateScript" disabled="@(selectedActionIds.Count == 0)">
                                    Generate SQL
                                </button>
                                @if (!string.IsNullOrEmpty(generatedScript))
                                {
                                    <button class="text-sm bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-300 px-4 py-1.5 rounded-lg font-medium transition-colors"
                                            @onclick="CopyScript">
                                        @(copyStatus ?? "Copy")
                                    </button>
                                    <button class="text-sm bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-300 px-4 py-1.5 rounded-lg font-medium transition-colors"
                                            @onclick="DownloadScript">
                                        Download .sql
                                    </button>
                                }
                                <button class="text-sm text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 px-2 py-1.5 ml-auto"
                                        @onclick="CloseScriptPanel">Close</button>
                            </div>

                            @if (!string.IsNullOrEmpty(generatedScript))
                            {
                                <pre class="bg-gray-900 dark:bg-black text-green-300 text-xs font-mono p-4 rounded-lg overflow-x-auto max-h-96 border border-gray-700">@generatedScript</pre>
                            }
                        </div>
                    }
                </div>
            }
            else if (!diffResult.IsIdentical && !canGenerateScript)
            {
                <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-xl mt-6 p-4">
                    <p class="text-sm text-amber-700 dark:text-amber-300">
                        <strong>Migration script generation not available</strong> — the two snapshots use different database engines (or one is Cosmos DB).
                        Cross-engine migration is not supported (and generally not safe to do automatically).
                    </p>
                </div>
            }
        }
    }
</div>

@code {
    // ── All snapshot summaries (loaded once on init / after diff) ─────
    private List<SnapshotSummary> allSnapshots = [];

    // ── Picker state ───────────────────────────────────────────────────
    private List<ConnectionProfile> connectionOptions = [];
    private int baselineConnId;
    private int compareConnId;
    private string baselineDb = "";
    private string compareDb = "";
    private List<string> baselineDbOptions = [];
    private List<string> compareDbOptions = [];
    private List<SnapshotSummary> baselineSnapshotOptions = [];
    private List<SnapshotSummary> compareSnapshotOptions = [];
    private int baselineSnapshotId;
    private int compareSnapshotId;

    // ── Diff state ─────────────────────────────────────────────────────
    private bool running;
    private string? errorMessage;
    private SchemaDiffResult? diffResult;
    private (string Baseline, string Compare)? diffLabels;

    private DatabaseSchema? baselineSchema;
    private DatabaseSchema? targetSchema;

    // ── Migration script panel ────────────────────────────────────────
    private enum ScriptDirection { BaselineToTarget, TargetToBaseline }
    private bool scriptPanelOpen;
    private ScriptDirection scriptDirection = ScriptDirection.BaselineToTarget;
    private List<MigrationAction> migrationActions = [];
    private HashSet<string> selectedActionIds = [];
    private string? generatedScript;
    private string? copyStatus;

    private bool canGenerateScript =>
        baselineSchema is not null &&
        targetSchema is not null &&
        baselineSchema.Provider == targetSchema.Provider &&
        baselineSchema.Provider != DatabaseProvider.CosmosDb;

    private string GetLabel(bool isBaseline)
    {
        if (diffLabels.HasValue)
            return isBaseline ? diffLabels.Value.Baseline : diffLabels.Value.Compare;
        return isBaseline ? "baseline" : "compare";
    }

    protected override async Task OnInitializedAsync()
    {
        await ReloadSnapshotsAsync();
        if (allSnapshots.Count >= 2)
            InitDefaults();
    }

    private async Task ReloadSnapshotsAsync()
    {
        allSnapshots = (await SnapshotRepo.GetAllAsync()).ToList();

        // Connections that actually have at least one snapshot
        var connIds = allSnapshots.Select(s => s.ConnectionId).Distinct().ToHashSet();
        var allConns = await ConnectionRepo.GetAllAsync();
        connectionOptions = allConns.Where(c => connIds.Contains(c.Id)).ToList();
    }

    private void InitDefaults()
    {
        // Default both sides to the most-recent snapshot's connection. Compare side
        // prefers the second-most-recent snapshot if available.
        var newest = allSnapshots[0];
        baselineConnId = newest.ConnectionId;
        baselineDb = newest.DatabaseName;
        baselineSnapshotId = newest.Id;

        var second = allSnapshots.Skip(1).FirstOrDefault() ?? newest;
        compareConnId = second.ConnectionId;
        compareDb = second.DatabaseName;
        compareSnapshotId = second.Id;

        RebuildDbOptions(true);
        RebuildDbOptions(false);
        RebuildSnapshotOptions(true);
        RebuildSnapshotOptions(false);
    }

    private void OnSideConnectionChanged(bool isBaseline, int newConnId)
    {
        if (isBaseline) baselineConnId = newConnId;
        else compareConnId = newConnId;

        RebuildDbOptions(isBaseline);
        // Pick the first DB available under the new connection
        var dbs = isBaseline ? baselineDbOptions : compareDbOptions;
        var newDb = dbs.FirstOrDefault() ?? "";
        if (isBaseline) baselineDb = newDb;
        else compareDb = newDb;

        RebuildSnapshotOptions(isBaseline);
        // Pick the first (most recent) snapshot
        var firstSnap = (isBaseline ? baselineSnapshotOptions : compareSnapshotOptions).FirstOrDefault();
        if (isBaseline) baselineSnapshotId = firstSnap?.Id ?? 0;
        else compareSnapshotId = firstSnap?.Id ?? 0;
    }

    private void OnSideDatabaseChanged(bool isBaseline, string newDb)
    {
        if (isBaseline) baselineDb = newDb;
        else compareDb = newDb;

        RebuildSnapshotOptions(isBaseline);
        var firstSnap = (isBaseline ? baselineSnapshotOptions : compareSnapshotOptions).FirstOrDefault();
        if (isBaseline) baselineSnapshotId = firstSnap?.Id ?? 0;
        else compareSnapshotId = firstSnap?.Id ?? 0;
    }

    private void RebuildDbOptions(bool isBaseline)
    {
        var connId = isBaseline ? baselineConnId : compareConnId;
        var dbs = allSnapshots
            .Where(s => s.ConnectionId == connId)
            .Select(s => s.DatabaseName)
            .Distinct()
            .OrderBy(d => d)
            .ToList();
        if (isBaseline) baselineDbOptions = dbs;
        else compareDbOptions = dbs;
    }

    private void RebuildSnapshotOptions(bool isBaseline)
    {
        var connId = isBaseline ? baselineConnId : compareConnId;
        var dbName = isBaseline ? baselineDb : compareDb;
        var snaps = allSnapshots
            .Where(s => s.ConnectionId == connId && s.DatabaseName == dbName)
            .OrderByDescending(s => s.ExtractedAt)
            .ToList();
        if (isBaseline) baselineSnapshotOptions = snaps;
        else compareSnapshotOptions = snaps;
    }

    private static string FormatSnapshotLabel(SnapshotSummary snap)
    {
        var ts = snap.ExtractedAt.ToLocalTime().ToString("g");
        return string.IsNullOrEmpty(snap.Name)
            ? $"📷 {ts}"
            : $"⭐ {snap.Name} — {ts}";
    }

    private async Task RunDiff()
    {
        if (baselineSnapshotId == 0 || compareSnapshotId == 0) return;
        if (baselineSnapshotId == compareSnapshotId)
        {
            errorMessage = "Please select two different snapshots.";
            return;
        }

        running = true;
        errorMessage = null;
        diffResult = null;
        diffLabels = null;
        ResetScriptState();

        try
        {
            var baseline = await SnapshotRepo.GetByIdAsync(baselineSnapshotId);
            var compare = await SnapshotRepo.GetByIdAsync(compareSnapshotId);
            var baseSummary = await SnapshotRepo.GetSummaryByIdAsync(baselineSnapshotId);
            var compSummary = await SnapshotRepo.GetSummaryByIdAsync(compareSnapshotId);

            if (baseline is null || compare is null || baseSummary is null || compSummary is null)
            {
                errorMessage = "Could not load one or both snapshots.";
                return;
            }

            diffResult = DiffService.Compare(baseline, compare);
            baselineSchema = baseline;
            targetSchema = compare;
            diffLabels = (LabelFor(baseSummary), LabelFor(compSummary));
        }
        catch (Exception ex) { errorMessage = $"Diff failed: {ex.Message}"; }
        finally { running = false; }
    }

    private static string LabelFor(SnapshotSummary s)
    {
        var conn = s.ConnectionName;
        var ts = s.ExtractedAt.ToLocalTime().ToString("g");
        return string.IsNullOrEmpty(s.Name)
            ? $"{conn} · {s.DatabaseName} @ {ts}"
            : $"{conn} · {s.DatabaseName} · \"{s.Name}\" @ {ts}";
    }

    // ── Migration script actions ─────────────────────────────────────

    private void ResetScriptState()
    {
        scriptPanelOpen = false;
        migrationActions = [];
        selectedActionIds = [];
        generatedScript = null;
        copyStatus = null;
        baselineSchema = null;
        targetSchema = null;
    }

    private void OpenScriptPanel()
    {
        if (baselineSchema is null || targetSchema is null || diffResult is null) return;
        scriptPanelOpen = true;
        RebuildActions();
    }

    private void CloseScriptPanel()
    {
        scriptPanelOpen = false;
        generatedScript = null;
        copyStatus = null;
    }

    private void SetDirection(ScriptDirection dir)
    {
        if (scriptDirection == dir) return;
        scriptDirection = dir;
        RebuildActions();
        generatedScript = null;
    }

    private void RebuildActions()
    {
        if (baselineSchema is null || targetSchema is null || diffResult is null) return;

        var (src, dst) = scriptDirection == ScriptDirection.BaselineToTarget
            ? (baselineSchema, targetSchema)
            : (targetSchema, baselineSchema);

        var directedDiff = DiffService.Compare(src, dst);
        var dialect = MigrationScriptGenerator.DialectFor(src.Provider);
        migrationActions = MigrationScriptGenerator.BuildActions(src, dst, directedDiff, dialect);
        selectedActionIds = new HashSet<string>(migrationActions.Select(a => a.Id));
    }

    private void SelectAllActions()
    {
        selectedActionIds = new HashSet<string>(migrationActions.Select(a => a.Id));
        generatedScript = null;
    }

    private void DeselectAllActions()
    {
        selectedActionIds.Clear();
        generatedScript = null;
    }

    private void ToggleAction(string id, bool isChecked)
    {
        if (isChecked) selectedActionIds.Add(id);
        else selectedActionIds.Remove(id);
        generatedScript = null;
    }

    private void GenerateScript()
    {
        if (baselineSchema is null || targetSchema is null) return;
        var (src, dst) = scriptDirection == ScriptDirection.BaselineToTarget
            ? (baselineSchema, targetSchema)
            : (targetSchema, baselineSchema);
        var dialect = MigrationScriptGenerator.DialectFor(src.Provider);
        var selected = migrationActions.Where(a => selectedActionIds.Contains(a.Id));
        var srcLabel = scriptDirection == ScriptDirection.BaselineToTarget ? GetLabel(true) : GetLabel(false);
        var dstLabel = scriptDirection == ScriptDirection.BaselineToTarget ? GetLabel(false) : GetLabel(true);
        generatedScript = MigrationScriptGenerator.AssembleScript(selected, dialect, srcLabel, dstLabel);
        copyStatus = null;
    }

    private async Task CopyScript()
    {
        if (string.IsNullOrEmpty(generatedScript)) return;
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", generatedScript);
            copyStatus = "Copied!";
            _ = InvokeAsync(async () => { await Task.Delay(2000); copyStatus = null; StateHasChanged(); });
        }
        catch { copyStatus = "Copy failed"; }
    }

    private async Task DownloadScript()
    {
        if (string.IsNullOrEmpty(generatedScript)) return;
        var bytes = System.Text.Encoding.UTF8.GetBytes(generatedScript);
        var fileName = $"migration_{DateTime.Now:yyyyMMdd_HHmmss}.sql";
        await JS.InvokeVoidAsync("downloadFileFromBytes", fileName, "text/plain", bytes);
    }
}
